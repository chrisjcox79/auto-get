                        <div id="page-title">
                            Clef博士的人事档案
                        </div>
                    

                    

                    



                    <div id="page-content">
                        

<script type="text/javascript" src="https://d3g0gp89917ko0.cloudfront.net/v--3e3a6f7dbcc9/common--javascript/yahooui/tabview-min.js">
</script>
<div id="wiki-tabview-660c79a8bd823ab476e75f92c4e656d5" class="yui-navset">
<ul class="yui-nav">
<li class="selected"><a href="javascript:;"><em>个人资料</em></a></li>
<li><a href="javascript:;"><em>SCP文档</em></a></li>
<li><a href="javascript:;"><em>其他文档</em></a></li>
<li><a href="javascript:;"><em>合著者名单</em></a></li>
