<div class="image-container floatleft"><img src="http://scp-jp.wdfiles.com/local--files/hal-aki-achievement-badges/%E5%AE%9F%E7%B8%BE_%E7%A7%A9%E5%BA%8F%E3%82%92%E5%AE%88%E3%82%8B%E6%82%AA%E9%AD%94.png" width="50" alt="%E5%AE%9F%E7%B8%BE_%E7%A7%A9%E5%BA%8F%E3%82%92%E5%AE%88%E3%82%8B%E6%82%AA%E9%AD%94.png" class="image" /></div>
