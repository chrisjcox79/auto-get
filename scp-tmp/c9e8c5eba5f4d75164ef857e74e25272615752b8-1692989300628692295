<script language="javascript">

var timer,op=0;
function Open(){
timer=setInterval(function(){              
op+=0.05;
if(op>=1){
op=1;
clearInterval(timer);
}
document.querySelector(".classified-info1").style.opacity=op; 
document.querySelector(".classified-info2").style.opacity=op; 
