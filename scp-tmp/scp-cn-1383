<div style="text-align: right;"><div class="page-rate-widget-box"><span class="rate-points">иҜ„еҲҶ:&nbsp;<span class="number prw54353">+33</span></span><span class="rateup btn btn-default"><a title="жҲ‘е–ңж¬ў" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.rate(event, 1)">+</a></span><span class="ratedown btn btn-default"><a title="жҲ‘дёҚе–ңж¬ў" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.rate(event, -1)">&#8211;</a></span><span class="cancel btn btn-default"><a title="еҸ–ж¶ҲжҲ‘зҡ„жҠ•зҘЁ" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.cancelVote(event)">x</a></span></div></div>
