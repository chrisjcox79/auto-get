<div class="scp-image-block block-right" style="width:400px;"><img src="http://scpsandboxcn.wikidot.com/local--files/bluecat-error/%E8%85%B0%E5%B0%81" style="width:400px;" alt="%E8%85%B0%E5%B0%81" class="image" />
