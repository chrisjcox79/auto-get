    position: relative;
    text-align: center;
    border-bottom: none;
    margin-bottom: 0;
}

.info-container {
    content: " ";
    width: 100%;
    text-align: center;
    bottom: 2em;
    margin-bottom: 1em;
}

.info-container h1 {
    text-align: center;
}

