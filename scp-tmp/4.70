:root {
    --barColour: #0f0505;
    --header-title: '彼基金会';
    --header-subtitle: '彼综督者工作室';
    --logo-image: url("https://i.loli.net/2020/11/26/FXZ67MJ85UlTGhI.png");
}

.bblock:hover {color: #FF6666}

.scp-image-block img {
    border: none;
}

::-webkit-scrollbar {
  width: 18px;
  background: #transparent;
}

::-webkit-scrollbar-track {
  background: #44030F
}

::-webkit-scrollbar-thumb {
  background: #000000;
  border: #84030F 1px solid;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #331111;
}

.coolcol .collapsible-block {
    background-color: #44030F;
    border-top: 0.125rem dashed #990100;
    border-bottom: 0.125rem dashed #990100;
}

.raisa_box{
border:solid 1px #252525;
background:#f2f2c2;
padding: 5px;
margin-bottom: 10px;
}

.amd_box{
border:solid 1px #44030F;
background:#990100;
padding: 5px;
margin-bottom: 10px;
}

div.resize img{
width: auto;
height: 150px;
float: left;
margin: 15px;
}

@media (max-width: 767px) {
    div.resize img {
        float: initial;
        margin: auto;
    }
}

.no {
    color: transparent;
}

.no::selection {
    color: #FF6666;
}

#page-title {
display: none;
}

/* 感谢Etinjat的代码协助！*/

.sel em {
    color: transparent;
    font-style:normal;
}

.sel em::selection {
    color: #FF6666;
}

.sel span[style*="text-decoration: underline;"]{
       text-decoration:none !important;
}

.sel span[style*="text-decoration: underline;"]::selection {
    color: #FF6666;
    background: #3c0000 !important;
}

.sel-before {
    z-index: 0;
    position: absolute;
}

.sel-before::selection {
    color: transparent;
}

.sel-after-r::selection {
    color: #FF6666;
}

.sel-after-b {
    z-index: 1;
    position: absolute;
    color: transparent;
}

.sel-after-b::selection {
    color: white;
}

.sel-after-g::selection {
    color: green;
}

.sel-blank{
    visibility: hidden;
}
</style>
<style>
.blbf-main {
    position: relative;
}

.blbf-main > br {
    display: none;
}

.blbf-main > div {
    display: block;
    width: -webkit-calc(100% - 3rem);
    width: -moz-calc(100% - 3rem);
    width: calc(100% - 3rem);
    padding: 0.75rem 0.75rem;
    margin: 1.5rem 0.5rem 0.5rem 0.5rem;
    border: 0.25rem rgb(var(--swatch-primary-darkest,144,25,1)) solid;
    background-color: rgb(234,234,234);
    color: rgb(var(--swatch-text-dark,51,51,51));
    position: relative;
    line-height: 1.5;
    -webkit-hyphens: auto;
       -moz-hyphens: auto;
        -ms-hyphens: auto;
            hyphens: auto;
    font-size: inherit;
}

.blbf-main > div > p:last-of-type {
    margin-bottom: 0;
}

.blbf-main > div::before {
    content: " ";
    position: absolute;
    top: -1.25rem;
    left: -0.5rem;
    padding: 0.5em 0.5em;
    font-size: -webkit-calc(12px + (14 - 12) * ( (100vw - 300px) / ( 800 - 300) ));
    font-size: -moz-calc(12px + (14 - 12) * ( (100vw - 300px) / ( 800 - 300) ));
    font-size: calc(12px + (14 - 12) * ( (100vw - 300px) / ( 800 - 300) ));
    font-family: var(--title-font, "Trebuchet MS", Trebuchet, Verdana, Arial, Helvetica);
    font-variant: all-petite-caps;
    font-weight: 600;
    background-color: rgb(var(--swatch-primary-darkest,144,25,1));
    color: rgb(var(--white-monochrome,255,255,255));
    letter-spacing: 0.05em;
    text-indent: 0;
    display: -webkit-box;
    display: -webkit-flex;
    display: -moz-box;
    display: -ms-flexbox;
    display: flex;
    line-height: 1;
    white-space: nowrap;
}
</style>
<style>
.blbf-main > div.blbf-dark {
    --blbf-bg-color: #3c0000;
    --blbf-txt-color: #FFFFFF;
    --blbf-bdr-color: #990100;
    --blbf-lbl-color: #990100;
    --blbf-lbltxt-color: #ffffff;
}

.blbf-main > div.blbf-dark {
    background-color: var(--blbf-bg-color);
    color: var(--blbf-txt-color);
    border-color: var(--blbf-bdr-color);
}

.blbf-main > div.blbf-dark::before {
    background-color: var(--blbf-lbl-color);
    color: var(--blbf-lbltxt-color);
}
</style>
<style>
.blbf-main > div.blbf-conprocs::before {
    content: "特殊收容措施";
}
</style>
<style>
.blbf-main > div.blbf-desc::before {
    content: "描述";
}
</style>
<style>
.blbf-main > div.blbf-conprocs::before {
    content: "特朱攵容措施";
}
</style>
