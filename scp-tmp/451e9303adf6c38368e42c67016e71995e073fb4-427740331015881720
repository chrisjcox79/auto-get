            select.setAttribute("onChange","tagInput2(this)");
            select.setAttribute("name","tag3");
            select.setAttribute("style","background-color:#FFFFCC;");
            var option = document.createElement("option");
            option.value = "";
            option.innerHTML = "...";
            select.appendChild(option);
