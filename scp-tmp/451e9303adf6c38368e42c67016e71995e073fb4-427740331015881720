//根据第2级菜单的类别，生成第3级菜单
function registerSearchTagOrCreateThirdSelecter(elm){
    var thirdSelecter = document.getElementById("tagSel3");
    var target = form.tag1.value;
    thirdSelecter.innerHTML = "";
