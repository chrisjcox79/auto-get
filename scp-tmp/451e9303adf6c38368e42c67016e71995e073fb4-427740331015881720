    for(i = 0; i < tagNumber; i++){
        s += "<a style='padding: 2px 4px; line-height: 1.2; border-radius: 6px; color: white; background-color: ";
        if(tagTable[i][0] == 0){
        s += "green";
        }else if(tagTable[i][0] == 1){
