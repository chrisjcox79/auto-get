/*
    RETRO AIAD Theme
    [2020 Wikidot Theme]
    By Placeholder McD
    Based on Y2K Theme created by Etoisle
*/

body,
h1,
h2,
h3,
h4,
h5,
h6,
#header h1 span,
#header h2 span::before,
.interwiki {
    font-family: "Microsoft Sans Serif", "黑体";
}

div#container-wrap {
    background-image: url(http://scp-wiki.wdfiles.com/local--files/theme:retro-aiad-theme/retroaiadbg.png);
}

div#header {
    background-image: url(http://scp-wiki.wdfiles.com/local--files/theme:retro-aiad-theme/retroaiadlogo.png);
}

#header h1 span {
    color: transparent;
    text-shadow: none;
}

#header h1 span::before {
    font-family: "Microsoft Sans Serif", "黑体";
    content: "信息技术部门";
    color: #ffffff;
    text-shadow: 3px 3px 0 rgba(0, 0, 0, 0.6);
}

#header h2 span::before {
    content: "人工智能应用科";
}
