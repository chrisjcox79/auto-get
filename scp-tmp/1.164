%3C/g%3E%3Cg xmlns=%22http://www.w3.org/2000/svg%22 class=%22rain%22 style=%22animation-duration:259ms;%22%3E%3Cpolygon class=%22st0%22 points=%22319.7,56.2 320.7,56.2 320.7,94.9 319.7,94.9%22 /%3E%3Cpolygon class=%22st0%22 points=%22319.7,-63.8 320.7,-63.8 320.7,-25.1 319.7,-25.1%22 /%3E%3C/g%3E%3Cg xmlns=%22http://www.w3.org/2000/svg%22 class=%22rain%22 style=%22animation-duration:248ms;%22%3E%3Cpolygon class=%22st0%22 points=%22251.5,13.9 251.9,13.9 251.9,38.8 251.5,38.8%22 /%3E%3Cpolygon class=%22st0%22 points=%22251.5,-106.1 251.9,-106.1 251.9,-81.2 251.5,-81.2%22 /%3E%3C/g%3E%3Cg xmlns=%22http://www.w3.org/2000/svg%22 class=%22rain%22 style=%22animation-duration:238ms;%22%3E%3Cpolygon class=%22st0%22 points=%227.4,102.1 8.5,102.1 8.5,116.4 7.4,116.4%22 /%3E%3Cpolygon class=%22st0%22 points=%227.4,-17.9 8.5,-17.9 8.5,-3.6 7.4,-3.6%22 /%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  background-size: 23.4375rem var(--header-height-on-desktop);
  background-repeat: repeat-x;
  background-position: 0 0;
}
#header h1,
#header h2 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -moz-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-pack: center;
  -webkit-justify-content: center;
  -moz-box-pack: center;
  -ms-flex-pack: center;
  justify-content: center;
  width: 100%;
}
#header h1 a,
#header h2 span {
  margin-left: 0;
}
#header h1 a {
  margin-top: -webkit-calc(((var(--header-height-on-desktop) / 2)) - 1.75rem);
  margin-top: -moz-calc(((var(--header-height-on-desktop) / 2)) - 1.75rem);
  margin-top: calc(((var(--header-height-on-desktop) / 2)) - 1.75rem);
  z-index: auto;
}
#header h1 a::before {
  --text-shadow: var(--white-monochrome);
  font-size: 5rem;
  color: rgb(12, 12, 12);
  color: rgb(var(--black-monochrome));
  text-shadow:
    0 0 0.3125rem rgba(var(--text-shadow), 0),
    0 0 0.625rem rgba(var(--text-shadow), 0.35),
    0 0 0.9375rem rgba(var(--text-shadow), 0),
    0 0 2.5rem rgba(var(--text-shadow), 0.35),
    0 0 5rem rgba(var(--text-shadow), 0);
  word-spacing: 0.25em;
  -webkit-transition: color 500ms, text-shadow 500ms;
  -moz-transition: color 500ms, text-shadow 500ms;
  -o-transition: color 500ms, text-shadow 500ms;
  transition: color 500ms, text-shadow 500ms;
}
#header h1 a:hover::before {
  color: rgb(192, 5, 4);
  color: rgb(var(--bright-accent));
  text-shadow:
    0 0 0.3125rem rgba(var(--black-monochrome), 1),
    0 0 0.625rem rgba(var(--black-monochrome), 1),
    0 0 0.9375rem rgba(var(--text-shadow), 0.35),
    0 0 2.5rem rgba(var(--text-shadow), 0.35),
    0 0 5rem rgba(var(--text-shadow), 0.35);
}
#header h2 span {
  margin-top: -webkit-calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
  margin-top: -moz-calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
  margin-top: calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
}
#header h2 span::before {
  --text-shadow: var(--white-monochrome);
  display: block;
  font-size: 1.5rem;
  font-weight: 600;
  color: rgb(48, 48, 52);
  color: rgb(var(--dark-gray-monochrome));
  text-align: center;
  text-shadow:
    0 0 0.125rem rgba(var(--text-shadow), 0.35),
    0 0 0.25rem rgba(var(--text-shadow), 0.35);
}

/* Top-Bar */
#top-bar div.top-bar > ul > li:hover,
#top-bar div.mobile-top-bar > ul > li:hover,
#top-bar div.top-bar > ul > li.sfhover,
#top-bar div.mobile-top-bar > ul > li.sfhover,
#top-bar div.top-bar > ul > li:focus-within,
#top-bar div.mobile-top-bar > ul > li:focus-within {
  background-color: rgba(12, 12, 12, 0.75);
  background-color: rgba(var(--swatch-menubg-black-color), 0.75);
}
#top-bar div.top-bar > ul > li > ul > li:hover,
#top-bar div.top-bar > ul > li > ul > li > ul > li:hover {
  background-color: transparent;
  background-color: rgba(var(--black-monochrome), 0.05);
}
#top-bar div.top-bar > ul > li > ul > li > a::before,
#top-bar div.top-bar > ul > li > ul > li > ul > li > a::before,
#top-bar div.top-bar > ul > li > ul > li > a:hover::before {
  background-color: rgba(12, 12, 12, 0.7);
  background-color: rgba(var(--black-monochrome), 0.7);
}
#top-bar div.mobile-top-bar > ul > li > ul > li:hover,
#top-bar div.mobile-top-bar > ul > li > ul > li > ul > li:hover {
  background-color: rgba(12, 12, 12, 0.5);
  background-color: rgba(var(--black-monochrome), 0.5);
}
#search-top-box-form input[type="submit"],
#search-top-box-form input[type="submit"]:hover,
#search-top-box-form input[type="submit"]:focus {
  background: rgb(144, 46, 47);
  background: rgb(var(--swatch-primary-darker));
}

/* Side-Bar */
#side-bar {
  background:
    /* Shadow covers */
      linear-gradient(
        rgba(var(--swatch-menubg-color),1) 30%,
        rgba(var(--swatch-menubg-color),0)),
      linear-gradient(
        rgba(var(--swatch-menubg-color),0),
        rgba(var(--swatch-menubg-color),1) 70%) 0 100%,

    /* Shadows */
      radial-gradient(farthest-side at 50% 0,
        rgba(var(--black-monochrome),0.5),
        rgba(var(--black-monochrome),0)),
      radial-gradient(farthest-side at 50% 100%,
        rgba(var(--black-monochrome),0.5),
        rgba(var(--black-monochrome),0)) 0 100%;
  background-color: rgba(var(--swatch-menubg-color),1);
  background-repeat: no-repeat;
  background-attachment: local, local, scroll, fixed;
  background-size: 100% 3rem, 100% 3rem, 100% 1.5rem, var(--sidebar-width-on-desktop) 1.5rem;
  background-position: top center, bottom center, top center, bottom -0.25rem left;
}
#side-bar .heading,
#side-bar .side-block > .collapsible-block:nth-child(1) .collapsible-block-folded {
  background-color: rgb(12, 12, 12);
  background-color: rgb(var(--black-monochrome));
}
#side-bar .side-block > .collapsible-block .collapsible-block-unfolded-link {
  background-color: rgba(57, 10, 22);
  background-color: rgba(var(--swatch-primary-darkest));
}
#side-bar .collapsible-block-link:hover {
  background-color: rgba(144, 46, 47);
  background-color: rgba(var(--swatch-primary-darker));
}
#side-bar div.menu-item a {
  -webkit-transition: background-color 80ms cubic-bezier(0.4, 0, 0.2, 1), color 500ms ease;
  -moz-transition: background-color 80ms cubic-bezier(0.4, 0, 0.2, 1), color 500ms ease;
  -o-transition: background-color 80ms cubic-bezier(0.4, 0, 0.2, 1), color 500ms ease;
  transition: background-color 80ms cubic-bezier(0.4, 0, 0.2, 1), color 500ms ease;
}
#side-bar div.menu-item a:hover {
  color: rgb(252, 252, 252);
  color: rgb(var(--swatch-menutxt-light-color));
}
#side-bar div.menu-item a::before,
#side-bar div.menu-item a:hover::before {
  background-color: rgba(48, 48, 52, 0.75);
  background-color: rgba(var(--dark-gray-monochrome), 0.75);
}
#side-bar div[style*="background-color"] {
  background-color: rgba(12, 12, 12, 0.09) !important;
  background-color: rgba(var(--black-monochrome), 0.09) !important;
}
#side-bar div[style*="#f0f0f0"] {
  background-color: transparent !important;
}

/* Rating */
.page-rate-widget-box,
#page-content .rate-box-with-credit-button {
  background-image: -webkit-linear-gradient(to bottom, rgb(var(--black-monochrome)) 0%, rgb(var(--black-monochrome)) 30%, rgb(var(--dark-accent)) 100%);
  background-image: -moz-linear-gradient(to bottom, rgb(var(--black-monochrome)) 0%, rgb(var(--black-monochrome)) 30%, rgb(var(--dark-accent)) 100%);
  background-image: linear-gradient(to bottom, rgb(var(--black-monochrome)) 0%, rgb(var(--black-monochrome)) 30%, rgb(var(--dark-accent)) 100%);
  background-color: rgb(252, 252, 252);
  background-color: rgb(var(--black-monochrome));
  border-color: rgba(160, 160, 160, 0.25);
  border-color: rgba(var(--light-gray-monochrome), 0.25);
}
#page-content .rate-box-with-credit-button > .creditButton > p > a::before {
  background-color: rgb(252, 252, 252);
  background-color: rgb(var(--swatch-menutxt-light-color));
}

/* Tabview */
.yui-navset .yui-nav,
.yui-navset .yui-navset-top .yui-nav {
  --box-shadow: rgb(var(--swatch-menubg-medium-color));
}
.yui-navset .yui-nav li,
.yui-navset .yui-navset-top .yui-nav li {
  --box-shadow: rgb(var(--gray-monochrome));
}
.yui-navset .yui-nav a:hover,
.yui-navset .yui-nav a:focus {
  background-color: rgb(66, 66, 72);
  background-color: rgb(var(--gray-monochrome));
}
.yui-navset .yui-nav .selected,
.yui-navset .yui-navset-top .yui-nav .selected,
.yui-navset .yui-nav .selected a:focus,
.yui-navset .yui-nav .selected a:active {
  background-color: rgb(12, 12, 12);
  background-color: rgb(var(--black-monochrome));
}

/* Footnotes */
.footnotes-footer {
  border-color: rgb(12, 12, 12);
  border-color: rgb(var(--black-monochrome));
}

/* Mobile */
@media only screen and (max-width: 768px) {
/* Mobile Search */
#search-top-box form[id="search-top-box-form"] input[type="submit"] {
  background-color: rgb(144, 46, 47);
  background-color: rgb(var(--swatch-primary-darker));
}
}
}
