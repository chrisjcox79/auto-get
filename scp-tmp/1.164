@supports((display: -ms-grid) or (display: grid)) {
:root {
  /* Header */
  --logo-image: none;
  --header-title: "黑 王";
  --header-subtitle: "神拘黑白 王宴绯青";

  /* Standard Colors */
  --bright-accent: 192, 5, 4;
  --medium-accent: 144, 46, 47;
  --dark-accent: 57, 10, 22;

  /* Primary Menu Colors */
  --swatch-menubg-hover-color: var(--dark-gray-monochrome);
  --swatch-topmenu-bg-color: var(--dark-gray-monochrome);

/* Rating Module Colors */
  --rating-module-button-color: var(--swatch-menutxt-light-color);
  --rating-module-button-credit-color: 52, 152, 219;
  --rating-module-text-color: var(--swatch-menutxt-light-color);

  /* Header Gradients */
  --gradient-header: linear-gradient(to top, rgb(var(--black-monochrome)), rgb(var(--black-monochrome)));
  --gradient-sidemenu-header: linear-gradient(10deg, rgb(var(--black-monochrome)) 0%, rgb(var(--dark-accent)) 100%);

  /* Ayers' Info Bar */
  --barColour: rgb(var(--black-monochrome));
}

/* Article Bottom Buttons */
div#page-options-bottom > a,
div#page-options-bottom-2 > a {
  background-color: rgba(66, 66, 72, 1);
  background-color: rgba(var(--swatch-menubg-medium-dark-color), 1);
  border-color: rgba(12, 12, 12, 1);
  border-color: rgba(var(--swatch-menubg-black-color), 1);
}
div#page-options-bottom > a:hover,
div#page-options-bottom > a:active,
div#page-options-bottom-2 > a:hover,
div#page-options-bottom-2 > a:active {
  background-color: rgba(57, 10, 22, 1);
  background-color: rgba(var(--swatch-primary-darkest), 1);
  border-color: rgba(12, 12, 12, 1);
  border-color: rgba(var(--swatch-menubg-black-color), 1);
}
#footer {
  background: rgb(48, 48, 52);
  background: rgb(var(--dark-gray-monochrome));
}

