<div class="list-pages-box">    <div class="list-pages-item">













<div class="anom-bar-container item-CN-1765 clear-4 safe none dark 需谨慎 {$american} lang-cn">
<div class="anom-bar">
<div class="top-box">
<div class="top-left-box"><span class="item"><span class="lang-cn">项目编号：</span><span class="lang-tr">項目編號：</span></span><span class="number">CN-1765</span></div>
<div class="top-center-box">
