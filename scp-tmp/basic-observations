<div>
<div class="image-container alignright"><img src="http://scp-wiki.wdfiles.com/local--files/basic-observations/Aklerep_Normal.png" style="margin-right: 20px;" width="90px" alt="Aklerep_Normal.png" class="image" /></div>
</div>
</div>
<div style="clear: right;"></div>
