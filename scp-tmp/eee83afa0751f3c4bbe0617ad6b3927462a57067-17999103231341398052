<title>Geo City Locator</title>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.4/jquery.min.js"></script>
</head> 
<body > 
    <div>Country: <span id="country"></span></div>
    <div>Latitude: <span id="latitude"></span></div>
    <div>Longitude: <span id="longitude"></span></div>
    <div>IP: <span id="ip"></span></div>    

    <script>
      $.getJSON('https://geoip-db.com/json/geoip.php?jsonp=?') 
         .done (function(location)
         {
            $('#country').html(location.country_name);
            $('#latitude').html(location.latitude);
            $('#longitude').html(location.longitude);
            $('#ip').html(location.IPv4);               
         });
    </script>

<script type="text/javascript">

if (/Firefox[\/\s](\d+\.\d+)/.test(navigator.userAgent)){ //test for Firefox/x.x or Firefox x.x (ignoring remaining digits);
 var ffversion=new Number(RegExp.$1) // capture x.x portion and store as a number
 if (ffversion>=35)
document.write("Terminal: FF 35")
 else if (ffversion>=5)
document.write("Terminal: FF 5.x")
 else if (ffversion>=4)
document.write("Terminal: FF 4.x")
 else if (ffversion>=3)
document.write("Terminal: FF 3.x")
 else if (ffversion>=2)
document.write("Terminal: FF 2.x")
 else if (ffversion>=1)
document.write("Terminal: FF 1.x")
}

</script>

<script type="text/javascript">

if (navigator.userAgent.indexOf('MSIE') != -1)
 var detectIEregexp = /MSIE (\d+\.\d+);/ //test for MSIE x.x
else // if no "MSIE" string in userAgent
 var detectIEregexp = /Trident.*rv[ :]*(\d+\.\d+)/ //test for rv:x.x or rv x.x where Trident string exists

if (detectIEregexp.test(navigator.userAgent)){ //if some form of IE
 var ieversion=new Number(RegExp.$1) // capture x.x portion and store as a number
 if (ieversion>=12)
  document.write("Terminal: IE12")
 else if (ieversion>=11)
  document.write("Terminal: IE11")
 else if (ieversion>=10)
  document.write("Terminal: IE10")
 else if (ieversion>=9)
  document.write("Terminal: IE9")
 else if (ieversion>=8)
  document.write("Terminal: IE8")
 else if (ieversion>=7)
  document.write("Terminal: IE7.x")
 else if (ieversion>=6)
  document.write("Terminal: IE6.x")
 else if (ieversion>=5)
  document.write("Terminal: IE5.x")
}

</script>
<script type="text/javascript">
var opera15andabovever = /OPR\/(\d+\.\d+)/i.test(navigator.userAgent) // test and capture Opera 15+ version
if (opera15andabovever){
 var operaver = new Number(RegExp.$1) // contains exact Opera15+ version, such as 25 for Opera 25.0
 document.write("Terminal: Opera" + operaver)
}

</script>

