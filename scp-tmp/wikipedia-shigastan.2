  }
}

#page-content .top-wrapper {
  float: left;
  width: 60%;
}

@media (max-width: 1000px) {
  #page-content .top-wrapper {
    float: none;
    width: 100%;
  }
}

#page-content .top-wrapper #toc {
  width: 20rem;
}

@media (max-width: 767px) {
  #page-content .top-wrapper #toc {
    width: 75vw;
  }
}

