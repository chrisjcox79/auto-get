  content: "目录";
  display: inline-block;
}

#page-content .top-wrapper #toc .title::before {
  font-size: 18px;
  content: "\f0c9";
  margin-right: 0.3rem;
  font-family: "FontAwesome";
  display: inline-block;
}

#page-content .details {
  float: right;
  width: 30%;
  padding: 20px;
  border: solid 1px #708090;
  background: #F5FFFA;
  text-align: center;
}

