    font-family: rift, sans-serif, Arial, "游明朝", YuMincho, "ヒラギノ明朝 ProN W3", "Hiragino Mincho ProN", "HG明朝E", "ＭＳ Ｐ明朝", "ＭＳ 明朝", 'Noto Serif KR', serif;
    font-size: 2.90em;
    flex-grow: 0;
    line-height: 1em;
}

.class1image {
    display: flex;
    align-items: center;
    width: 5em;
    flex-grow: 0.25;
}

.class1image img {
    height: 6em;
    max-width: initial;
}

.item1 {
    white-space: nowrap;
    text-align: right;
    display: flex;
    flex-direction: column;
    flex-grow: 0.25;
}

.item1 > div {
    color: #0c0c0c;
    font-family: rift, sans-serif, Arial, "游明朝", YuMincho, "ヒラギノ明朝 ProN W3", "Hiragino Mincho ProN", "HG明朝E", "ＭＳ Ｐ明朝", "ＭＳ 明朝", 'Noto Serif KR', serif;
    font-size: 2em;
    font-weight: normal;
    text-align: center;
    transform: scale(1, 1);
    height: 1em;
    flex-grow: 0;
    line-height: 1;
}

.PL div > span {
    font-size: 0.75em;
}

.ES div > span {
    font-size: 0.85em;
}

.scale {
    margin: 0;
    padding: 0;
    border: none;
    width: 100%;
    max-width: 100% !important;
    display: flex;
    align-items: stretch;
    justify-content: center;
}

.scape > div {
    margin: 0 !important;
    padding: 0 !important;
    flex-grow: 2;
}

.objclass {
    display: relative;
    flex-grow: 2 !important;
    display: flex;
    align-items: center;
}

.objclass > div {
    position: absolute;
}

.obj-left {
    width: 1em;
    height: 1em;
    left: 0;
}

