<td>手枪20</td>
</tr>
<tr>
<td>头顶10</td>
<td>躲藏10</td>
<td>历史20</td>
<td>跳跃25</td>
<td>踢25</td>
<td>法律5</td>
</tr>
<tr>
<td><span style="color: #ffd306">图书馆利用50</span></td>
<td><span style="color: #ffd306">聆听55</span></td>
<td>钳工1</td>
<td>机关枪15</td>
<td>武术1</td>
<td>机器维修20</td>
</tr>
<tr>
<td><span style="color: #ffd306">医学67</span></td>
<td>自然史10</td>
<td>领航10</td>
<td>神秘学5</td>
<td>重型机械1</td>
<td>拉丁语2</td>
</tr>
<tr>
<td><span style="color: red">英语80</span></td>
<td><span style="color: red">母语75</span></td>
<td>劝说16</td>
<td>药剂学1</td>
<td>摄影10</td>
