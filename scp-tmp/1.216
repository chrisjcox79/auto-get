    .class1image img {
        height: 4rem;
    }

    .item1 > div {
        font-size: 4.2vw;
        line-height: 1.5;
    }

    .item1 > .itemnum {
        font-size: 1.5em !important;
    }

    .obj-right {
        background-position: -0.03em;
    }

