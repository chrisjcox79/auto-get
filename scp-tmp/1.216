<style>
@import url(http://scp-wiki.wdfiles.com/local--code/info%3Astyle/1);
</style>
<style>
:root {
    --info-circle-size: 150px;
    --info-up-bg: lightgreen;
    --info-down-bg: pink;
    --info-border-color: #b01;
}
.list-pages-box .rate_t3 {
    display: inline-block;
}
.list-pages-box .rate_t3 .wrap {
    border-bottom: 1px solid var(--info-border-color);
    display: inline-block;
    width: var(--info-circle-size);
    height: calc(var(--info-circle-size) / 2);
    overflow: hidden;
}
.list-pages-box .rate_t3 .cir {
    width: var(--info-circle-size);
    height: var(--info-circle-size);
    margin: 0;
    padding: 0;
    transform: rotate(-90deg);
}
.list-pages-box .rate_t3 .rad {
    width: calc(100% - 2px);
    height: 0;
    padding: calc(50% - 1px) 0 0;
    margin: 0;
    border: solid var(--info-border-color);
}
.list-pages-box .rate_t3 .rad_def {
    background: gray;
    border-radius: 50%;
    width: calc(100% - 2px);
    height: 0;
    padding: calc(100% - 2px) 0 0;
    margin: 0;
    border: 1px solid var(--info-border-color);
}
.list-pages-box .rate_t3 .uv {
    border-radius: 100rem 100rem 0 0;
    background: var(--info-up-bg);
    border-width: 1px 1px 0;
}
.list-pages-box .rate_t3 .dv {
    border-radius: 0 0 100rem 100rem;
    background: var(--info-down-bg);
    border-width: 0 1px 1px;
}
</style>
<style>
@import url(http://scp-wiki-cn.wdfiles.com/local--code/theme%3Apenumbra/1);
</style>
<style>
:root {
  --accentColor: #D02727;
}

/* 版头警告 */
.warning{
    border: solid 2px #D02727;
    padding: 5px;
    margin-bottom: 10px;
    border-radius: 10px;
}

/* 实验记录 */
.exp{
    border-left: solid 2px #D02727;
    border-right: solid 2px #D02727;
    padding: 5px;
    margin-left: 3em;
    margin-right: 3em;
    background-color: #21252e;
    border-radius: 10px;
}

/* 变蓝！ */
.blue a{
    font-weight: normal;
    color: #4E8EF5;
    font-size: 100%;
}
.blue a:hover{
    color: #ffffff;
    background-color: #4E8EF5;
}

/* 感谢Sekai_s的代码援助！ */
.image-wrap {
  display: -webkit-box;
  display: -webkit-flex;
  display: -moz-box;
  display: -ms-flexbox;
  display: flex;
  width: 400px;
  margin: 0 auto;
}
.image-wrap a:hover {
  background-color: transparent;
}
.image-wrap > div {
  -webkit-box-flex: 1;
  -webkit-flex-grow: 1;
  -moz-box-flex: 1;
  -ms-flex-positive: 1;
  flex-grow: 1;
  -webkit-flex-shrink: 0;
  -ms-flex-negative: 0;
  flex-shrink: 0;
  width: 100%;
}
.image-wrap > div:nth-child(1) > .image {
  width: 100%;
}
.image-wrap > div:nth-child(2) {
  position: relative;
  left: -100%;
}
.image-wrap > div:nth-child(2) > div {
  display: -webkit-box;
  display: -webkit-flex;
  display: -moz-box;
  display: -ms-flexbox;
  display: flex;
}
.image-wrap > div:nth-child(2) > div.col-wrap {
  -webkit-flex-wrap: wrap;
  -ms-flex-wrap: wrap;
  flex-wrap: wrap;
  margin: 26% 3% 0;
}
.image-wrap > div:nth-child(2) > div.link-wrap {
  -webkit-justify-content: space-between;
  justify-content: space-between;
  margin: 11.5% 5% 0 3%;
}

.col-wrap > .colmod-block {
  width: 33.33%;
}
.col-wrap > .colmod-block > ul > li > .colmod-link-top a {
  box-sizing: border-box;
  padding-bottom: calc(100% - 10px);
  width: 100%;
  height: 0;
  font-size: 0;
  border: 5px solid transparent;
}
.col-wrap > .colmod-block > ul > li.folded > .colmod-link-top a:first-child,
.col-wrap > .colmod-block > ul > li.unfolded > .colmod-link-top a:not(:first-child) {
  display: block;
}
.col-wrap > .colmod-block > ul > li.unfolded > .colmod-link-top a:not(:first-child) {
  border: 5px solid #4e8ef5;
}

.link-wrap > .refresh {
  padding-bottom: 16%;
  width: 16%;
  height: 0;
}
.link-wrap > .submit{
  width: 45%;
}
/* 赞美色开！ */
