<style>
.email-example .collapsible-block-folded a.collapsible-block-link {
    animation: blink 0.8s ease-in-out infinite alternate;
}
@keyframes blink {
    0% { color: transparent; }
    50%, 100% { color: #b01; }
}
.email {border: solid 2px #000000; width: 88%; padding: 1px 15px; margin: 10px; box-shadow: 0 1px 3px rgba(0,0,0,.5)}
.email-example a.collapsible-block-link {font-weight: bold;}
.tofrom {margin-left: 10px; margin-top: 5px; padding: 1px 15px; border-left: solid 3px maroon}

:root {
--theme-base: "black-highlighter";
  --theme-id: "swirling-ashes";
  --theme-name: "Swirling Ashes Theme";
--logo-image: url("http://scpsandboxcn.wdfiles.com/local--files/15999999/SINNERSTOP");
    --header-title: "阻 罪 者 联 合 体";
    --header-subtitle: "阻罪非为得恕者，得恕非为有罪者。";
 --gradient-header: linear-gradient(transparent, transparent);
  --diagonal-stripes: linear-gradient(transparent, transparent);
  --sky-length: 15;
  --sky-time: 60s;
}

body::before,
div#container-wrap-wrap::before,
div#container-wrap-wrap::after,
body::after {
  content: "";
  position: absolute;
  height: var(--header-height-on-desktop); width: 100%; top: 0; left: 0;
  pointer-events: none;
}

div#container-wrap-wrap::before {
  background-image: url(https://cdn.pixabay.com/photo/2016/07/19/22/03/forest-1529055_960_720.jpg);
 background-size: auto var(--header-height-on-desktop);
}

@keyframes shine {
  0%, 40%, 100% { opacity: 0.2; }
  55%, 77% { opacity: 0; }
}

div#container-wrap-wrap::after, body::after {
  background-size: var(--ashes-width) var(--header-height-on-desktop);
  background-repeat: repeat-x;
  animation: ashes-move linear var(--ashes-move-duration),
             ashes-fade ease calc(var(--sky-time) * 3);
  animation-iteration-count: infinite;
  animation-fill-mode: both;
}
div#container-wrap-wrap::after {
  background-image: url(http://scp-wiki.wdfiles.com/local--files/theme%3Aswirling-ashes/ashes-large.png);
  --ashes-move-duration: 27s;
  --ashes-width: 500px;
  --ashes-opacity: 0.5;
}
body::after {
  background-image: url(http://scp-wiki.wdfiles.com/local--files/theme%3Aswirling-ashes/ashes-small.png);
  --ashes-move-duration: 20s;
  --ashes-width: 800px;
  --ashes-opacity: 0.4;
}
@keyframes ashes-move {
  from { background-position: 0 0; }
  to { background-position: var(--ashes-width) 0; }
}
@keyframes ashes-fade {
  0%, 85%, 96%, 100% { opacity: var(--ashes-opacity); }
  88.66%, 92.33% { opacity: 0.1; }
}

#header h1 a::before {
  --text-shadow: var(--black-monochrome));
  font-size: 3rem;
  color: rgb(166, 166, 180);
  text-shadow:
    0 0 0.3125rem rgba(var(--text-shadow), 0),
    0 0 0.625rem rgba(var(--text-shadow), 0.35),
    0 0 0.9375rem rgba(var(--text-shadow), 0),
    0 0 2.5rem rgba(var(--text-shadow), 0.35),
    0 0 5rem rgba(var(--text-shadow), 0);
  word-spacing: 0.25em;
  -webkit-transition: color 500ms, text-shadow 500ms;
  -moz-transition: color 500ms, text-shadow 500ms;
  -o-transition: color 500ms, text-shadow 500ms;
  transition: color 500ms, text-shadow 500ms;
}
#header h1 a:hover::before {
  color: rgb(117, 0, 27);
  text-shadow:
    0 0 0.3125rem rgba(var(--black-monochrome), 1),
    0 0 0.625rem rgba(var(--black-monochrome), 1),
    0 0 0.9375rem rgba(var(--text-shadow), 0.35),
    0 0 2.5rem rgba(var(--text-shadow), 0.35),
    0 0 5rem rgba(var(--text-shadow), 0.35);
}

#header h2 span {
  margin-top: -webkit-calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
  margin-top: -moz-calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
  margin-top: calc(((var(--header-height-on-desktop) / 2) + 1.25rem));
}
#header h2 span::before {
  --text-shadow:var(--dark-gray-monochrome);
  display: block;
  font-size: 1.5rem;
  font-weight: 600;
  color: rgb(60, 60, 69);
  text-align: center;
  text-shadow:
    0 0 0.125rem rgba(var(--text-shadow), 0.35),
    0 0 0.25rem rgba(var(--text-shadow), 0.35);
}
</style>
