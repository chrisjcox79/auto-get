.obj-right > div {
    display: flex;
    flex-grow: 2;
    justify-content: center;
    width: calc(100% - 2.5rem);
    position: absolute;
    right: 0;
    font-size: 1.5em;
}

@media (max-width: 540px) {
    .class1 > div {
        font-size: 5.8vw;
        font-weight: bold !important;
    }

    .class1image {
        width: 3em;
