<div class="carousel-container {$position}" style="width: calc({$width} + 34px);"><iframe src="http://scp-wiki-cn.wikidot.com/local--code/component%3Acarousel/1#?images={$images}&amp;wiki={$wiki}&amp;page={$page}&amp;interval={$interval}&amp;background={$background}&amp;options={$options}" align="" frameborder="" height="" scrolling="no" width="" class="" style="width: calc({$width} + 34px); height: calc({$height} + 6px);"></iframe>
<div class="carousel-caption-wrapper">
<div class="carousel-caption {$no-caption}" style="width: calc({$width});">
<p>{$caption}</p>
</div>
</div>
</div>



