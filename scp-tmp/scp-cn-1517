    transition: border-top-color 0.2s linear;
    border-top: solid rgb(66, 66, 72) 5px;
}
/* End of addendum tag */
#page-content .collapsible-block-content::after {
    content:"附录结束";
    font-weight: bold;
    font-size: 95%;
    color:white;
    background: rgb(66, 66, 72);
    width: 150px;
    border-radius: 3px;
