<strong><span style="color: white"><tt><span style="white-space: pre-wrap;">&#32;&#32;&#32;&#32;&#32;raise&#32;FileNotFoundError(obj)</span></tt></span></strong><br />
<strong><span style="color: white"><tt><span style="white-space: pre-wrap;">&#32;FileNotFoundError:&#32;[Errno&#32;2]&#32;No&#32;such&#32;file&#32;or&#32;directory:&#32;'CAM-5.ogg'</span></tt></span></strong></p>
</div>
