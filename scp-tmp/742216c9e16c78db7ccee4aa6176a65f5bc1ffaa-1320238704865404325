<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html id="html-block-html" xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en"><head><meta http-equiv="Content-type" content="text/html; charset=utf-8"/><link rel="stylesheet" href="/common--theme/base/css/html-block.css"/></head><body>

<style type="text/css">
@import url(http://scp-jp.wdfiles.com/local--files/japanese-syntax/scp-WikidotCss.css);

body *{
pointer-events: none;
}

img{
position:absolute;
bottom: 0;
left: 0;
right: 0;
margin: 0 auto;
max-height: 100vh;
pointer-events: auto;
}

.remove{
display: none;
}

.up{
animation: upmove 0.5s cubic-bezier(0.9,1,0.9,1) 1s 1 both;
}

@keyframes upmove{
0%{top: 100vh;}
70%{top: 5vh;}
85%{top: 0;}
100%{top: 5vh;}
}

.down{
animation: downmove 0.5s cubic-bezier(0.2,0,0.2,0) 0s 1 both;
}

@keyframes downmove{
0%{top: 5vh;}
15%{top: 0;}
30%{top: 5vh;}
100%{top: 100vh;}
}

.down img{
pointer-events: none;
}

</style>

<script type="text/javascript" src="http://scp-jp.wdfiles.com/local--files/japanese-syntax/scpHTMLblockCtrl_ver1_ex.js"></script>

<div id="area" class="up" style="position:relative; height: 100vh; top: 5vh;">
<a href="javascript:remotePop1()">
<img src="http://ja.scp-wiki.net/local--files/scp-2000-jp/inu_mail.png" alt="打开邮件" id="inu1" class="">
</a>
<a href="javascript:remotePop2()">
<img src="http://ja.scp-wiki.net/local--files/scp-2000-jp/inu_close.png" alt="抚摸" id="inu2" class="remove">
</a>
<img src="http://ja.scp-wiki.net/local--files/scp-2000-jp/inu_smile.png" id="inu3" class="remove">
</div>

<script type="text/javascript">
function remotePop1(){
document.getElementById("inu1").classList.add("remove");
document.getElementById("inu2").classList.remove("remove");
window.parent.window.location.href="http://scp-wiki-cn.wikidot.com/scp-2000-jp#u-letter-popup";
}
function remotePop2(){
document.getElementById("inu2").classList.add("remove");
document.getElementById("inu3").classList.remove("remove");
setTimeout(function(){
document.getElementById("inu3").classList.add("remove");
document.getElementById("inu2").classList.remove("remove");
document.getElementById("area").classList.add("down");
setTimeout(function(){
window.parent.window.location.href="http://scp-wiki-cn.wikidot.com/scp-2000-jp#u-end";
setTimeout(function(){
window.parent.window.location.href="http://scp-wiki-cn.wikidot.com/scp-2000-jp#u-shut-popup";},4000);
},1500);
}, 1000);
}
</script>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body></html>