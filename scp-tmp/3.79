<div class="scpnet-interwiki-wrapper"><div class="list-pages-box">    <div class="list-pages-item">


<p><iframe src="http://scp-wiki-cn.wdfiles.com/local--files/nav%3Aside/interwikiFrame.html?category=_default&pagename=scp-cn-763" class="html-block-iframe scpnet-interwiki-frame" name="interwikiFrame"></iframe></p>
