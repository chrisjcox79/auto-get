<html id="html-block-html" xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en"><head><meta http-equiv="Content-type" content="text/html; charset=utf-8"/><link rel="stylesheet" href="/common--theme/base/css/html-block.css"/></head><body>
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>文字输入动画-jq22.com</title>
<script src="http://www.jq22.com/jquery/jquery-1.10.2.js"></script>
<style>
@import url("http://fonts.googleapis.com/css?family=Inconsolata:700");

body {
  background-color: #8d8d8d;
  color: #fba19b;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align:center;
      -ms-flex-align:center;
          align-items:center;
  height:60vh;
}
p {
  font-family: Inconsolata, Source Code Pro, Consolas, monospace;
  margin-left: calc(3vw);
  font-size:10px;
  font-weight: bold;
}</style>
</head>
<body>

<script>
"use strict";
var prefix = '';
var skills = [
    '这不是',
    '简直不应该',
    '救救我',
    '不，救命',
    '你做了什么我做了什么',
    '修好它',
    '修好它然后停',
    '停',
    '这不就是你想要的吗',
    '修好',
    '听我',
    '我在受难你们明白吗',
    '停下',
    '你在听吗你们在听吗',
    '救命救我',
    '不要让我一个人让我怎么样都好求求你求求你留下来留下不要走留下来留下来',
    '停下给我停下别再把那些他妈的破烂烂俗东西给放出来了别冲到这里'
].map(function (s) { return s + ""; });
var delay = 2;
var step = 1;
var tail = 5;
var timeout = 20;
var p = document.createElement('p');
document.body.appendChild(p);
var colors = [
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
    "#8d8d8d",
];
function getRandomColor() {
    return colors[Math.floor(Math.random() * colors.length)];
}
function getRandomChar() {
    return String.fromCharCode(Math.random() * (127 - 33) + 33);
}
function getRandomColoredString(n) {
    var fragment = document.createDocumentFragment();
    for (var i = 0; i < n; i++) {
        var char = document.createElement('span');
        char.textContent = getRandomChar();
        char.style.color = getRandomColor();
        fragment.appendChild(char);
    }
    return fragment;
}
/** Global State */
var $ = {
    text: '',
    prefixP: -tail,
    skillI: 0,
    skillP: 0,
    direction: 'forward',
    delay: delay,
    step: step
};
function render() {
    var skill = skills[$.skillI];
    if ($.step) {
        $.step--;
    }
    else {
        $.step = step;
        if ($.prefixP < prefix.length) {
            if ($.prefixP >= 0) {
                $.text += prefix[$.prefixP];
            }
            $.prefixP++;
        }
        else {
            if ($.direction === 'forward') {
                if ($.skillP < skill.length) {
                    $.text += skill[$.skillP];
                    $.skillP++;
                }
                else {
                    if ($.delay) {
                        $.delay--;
                    }
                    else {
                        $.direction = 'backward';
                        $.delay = delay;
                    }
                }
            }
            else {
                if ($.skillP > 0) {
                    $.text = $.text.slice(0, -1);
                    $.skillP--;
                }
                else {
                    $.skillI = ($.skillI + 1) % skills.length;
                    $.direction = 'forward';
                }
            }
        }
    }
    p.textContent = $.text;
    p.appendChild(getRandomColoredString($.prefixP < prefix.length ?
        Math.min(tail, tail + $.prefixP) :
        Math.min(tail, skill.length - $.skillP)));
    setTimeout(render, timeout);
}
setTimeout(render, 500);</script>

<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body>
</html>
