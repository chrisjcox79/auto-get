					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/twilit" onclick="WIKIDOT.page.listeners.userInfo(6592438); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=6592438&amp;amp;size=small&amp;amp;timestamp=1610248398" alt="Twilit" style="background-image:url(http://www.wikidot.com/userkarma.php?u=6592438)"/></a><a href="http://www.wikidot.com/user:info/twilit" onclick="WIKIDOT.page.listeners.userInfo(6592438); return false;" >Twilit</a></span> <span class="odate time_1610236011 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">09 Jan 2021 23:46</span>
