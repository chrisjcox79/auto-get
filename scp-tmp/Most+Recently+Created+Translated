&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/katja1453&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6985866&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610198948&quot; alt=&quot;Katja1453&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6985866)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/katja1453&quot;  &gt;Katja1453&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
