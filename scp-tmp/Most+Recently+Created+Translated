&lt;p&gt;&lt;strong&gt;SCP-3327 &amp;quot;苏联掩体群&amp;quot; by：&lt;/strong&gt;&lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/drmorris&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=2231487&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610198948&quot; alt=&quot;DrMorris&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=2231487)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/drmorris&quot;  &gt;DrMorris&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
&lt;hr /&gt;
&lt;p&gt;&lt;strong&gt;译者：&lt;/strong&gt;&lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/scotoma&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=3929032&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610198948&quot; alt=&quot;Scotoma&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=3929032)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/scotoma&quot;  &gt;Scotoma&lt;/a&gt;&lt;/span&gt;&lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/h-storm-z&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=4761754&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610198948&quot; alt=&quot;H-Storm Z&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=4761754)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/h-storm-z&quot;  &gt;H-Storm Z&lt;/a&gt;&lt;/span&gt;，原文链接&lt;a href=&quot;http://www.scpwiki.com/scp-3327&quot; target=&quot;_blank&quot;&gt;http://www.scpwiki.com/scp-3327&lt;/a&gt;&lt;/p&gt;
