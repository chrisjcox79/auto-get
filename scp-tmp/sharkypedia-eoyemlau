.circle-1 .line-box div.line:nth-of-type(6),
.circle-1 .graph-box div.graph:nth-of-type(6){
transform: rotate(calc(360deg / 6 * 5));
}

.circle-1 .scale-box div.scale:nth-of-type(1){
