}
}

.circle-1 .line-box .line,
.circle-1 .graph-box .graph{
position: absolute;
left: 0;
right: 0;
margin: 0 auto;
width: 2px;
height: 50%;
background: #888;
transform-origin: 50% 100%;
}

.circle-1 .scale-box .scale{
