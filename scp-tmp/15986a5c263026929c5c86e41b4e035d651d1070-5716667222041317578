<script>
var date;
today = new Date();
date =  "根据基金会手册第五条规定，你的位置信息已被锁定。<br /><br />"+"你的登入位置："+(today.getFullYear()) + "年" + (today.getMonth() + 1 ) + "月" + today.getDate() + "日 ";
document.getElementById("IPloacation").innerHTML= date + " ，"+"位于" + localAddress["province"]  +" "+ "<br />你的IP地址："+ " " +returnCitySN["cip"]+ " " +"已经锁定";

var x=document.getElementById("demo");

function getLocation()
  {
  if (navigator.geolocation)
    {
    navigator.geolocation.getCurrentPosition(showPosition,showError);
    }
  else{x.innerHTML=" ";}
  }
function showPosition(position)
   {
var EW = position.coords.longitude;
var NS = position.coords.latitude ;
if(EW != 0 && NS != 0){
  x.innerHTML=
  "你现在的位置是："  +
"<br /> " +
  "<br /> 经度: " + EW +
"<br /> " +
  "<br /> 纬度: " + NS +
"<br /> " +
  "<br /> 精度: " +  position.coords.accuracy    ;

document.getElementById("IPlocation").innerHTML="注意："+"<br />您的地理坐标已经被上传，"+"<br />请等待附近的sdxzdgsrdgvexdf";
  }

        }  
function showError(error)
  {
  switch(error.code)
    {
    case error.PERMISSION_DENIED:
      x.innerHTML="警告，你具体的地理位置已经被基金会定位，请在原地等候安保人员的安排。"
      break;
    case error.POSITION_UNAVAILABLE:
      x.innerHTML="警告，你具体的地理位置已经被基金会定位，请在原地等候安保人员的安排。"
      break;

    case error.TIMEOUT:
      x.innerHTML="警告，你具体的地理位置已经被基金会定位，请在原地等候安保人员的安排。"
      break;

    case error.UNKNOWN_ERROR:
      x.innerHTML="警告，你具体的地理位置已经被基金会定位，请在原地等候安保人员的安排。"
      break;
    }
  }
</script>
