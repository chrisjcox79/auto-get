&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/crow-pablo&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6518998&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248389&quot; alt=&quot;Crow pablo&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6518998)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/crow-pablo&quot;  &gt;Crow pablo&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
