&lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/diamond-apple&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=5190582&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248386&quot; alt=&quot;Diamond_Apple&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=5190582)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/diamond-apple&quot;  &gt;Diamond_Apple&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
