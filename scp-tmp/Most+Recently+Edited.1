&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Atlas&lt;sup class=&quot;footnoteref&quot;&gt;&lt;a id=&quot;footnoteref-920659-29&quot; href=&quot;javascript:;&quot; class=&quot;footnoteref&quot;  &gt;29&lt;/a&gt;&lt;/sup&gt;&lt;/td&gt;
&lt;td&gt;项目确保人类和/或周围现实的存在，不应受到限制。&lt;/td&gt;
&lt;td&gt;&lt;a class=&quot;newpage&quot; href=&quot;http://scp-wiki-cn.wikidot.com/scp-1331-ru&quot;&gt;SCP-1331-RU&lt;/a&gt;，&lt;a href=&quot;http://scp-wiki-cn.wikidot.com/scp-1399-ru&quot;&gt;SCP-1399-RU&lt;/a&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Axiom&lt;/td&gt;
