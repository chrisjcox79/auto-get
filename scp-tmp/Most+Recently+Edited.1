&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/joke3579&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=4915133&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248387&quot; alt=&quot;joke3579&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=4915133)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/joke3579&quot;  &gt;joke3579&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
