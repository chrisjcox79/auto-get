&lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/yoghurt-rescuer&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=3167340&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248387&quot; alt=&quot;Yoghurt-rescuer&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=3167340)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/yoghurt-rescuer&quot;  &gt;Yoghurt-rescuer&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
