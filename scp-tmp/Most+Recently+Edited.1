&lt;span style=&quot;font-size:80%;&quot;&gt;&lt;strong&gt;&lt;a href=&quot;http://scp-wiki-cn.wikidot.com/new-faces-overture&quot;&gt;&amp;lt;&amp;lt; 新面貌：序章&lt;/a&gt;&lt;/strong&gt; | &lt;strong&gt;招募行动&lt;/strong&gt; | &lt;strong&gt;&lt;a class=&quot;newpage&quot; href=&quot;http://scp-wiki-cn.wikidot.com/welcome-to-yellowstone&quot;&gt;Welcome to Yellowstone &amp;gt;&amp;gt;&lt;/a&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;
