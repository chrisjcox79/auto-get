&lt;p&gt;&lt;iframe src=&quot;http://scp-wiki-cn.wikidot.com/credit:backmodule/code/1&quot; align=&quot;&quot; frameborder=&quot;&quot; height=&quot;&quot; scrolling=&quot;&quot; width=&quot;&quot; class=&quot;&quot; style=&quot;&quot;&gt;&lt;/iframe&gt;&lt;/p&gt;
