&lt;blockquote&gt;
&lt;div style=&quot;text-align: center;&quot;&gt;
&lt;p&gt;&lt;span class=&quot;ruby&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;战争中没有什么好东西。&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;span class=&quot;rt&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;There is nothing good in war.&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;ruby&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;除了它的结束。&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;span class=&quot;rt&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;Except its ending.&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span class=&quot;ruby&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;——亚伯拉罕·林肯&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;span class=&quot;rt&quot;&gt;&lt;em&gt;&lt;strong&gt;&lt;span style=&quot;font-size:150%;&quot;&gt;——Abraham Lincoln&lt;/span&gt;&lt;/strong&gt;&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;
&lt;/blockquote&gt;
