&lt;span style=&quot;color: transparent&quot;&gt;·&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;color: transparent&quot;&gt;·&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;color: transparent&quot;&gt;·&lt;/span&gt;&lt;/p&gt;
&lt;/div&gt;

