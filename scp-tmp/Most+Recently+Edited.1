&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&amp;#32;&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&amp;#32;&lt;/span&gt;&lt;br /&gt;
&lt;span style=&quot;font-size:0%;&quot;&gt;感谢hoah2333提供的淡出文字代码。&lt;/span&gt;&lt;br /&gt;&lt;/p&gt;
&lt;div style=&quot;text-align: center;&quot;&gt;
