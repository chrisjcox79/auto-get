&lt;div class=&quot;image-container floatleft&quot;&gt;&lt;img src=&quot;http://scp-jp.wdfiles.com/local--files/hal-aki-achievement-badges/%E5%AE%9F%E7%B8%BE_%E4%BA%BA%E9%A1%9E%E5%AD%A6%E8%80%85.png&quot; width=&quot;50&quot; alt=&quot;%E5%AE%9F%E7%B8%BE_%E4%BA%BA%E9%A1%9E%E5%AD%A6%E8%80%85.png&quot; class=&quot;image&quot; /&gt;&lt;/div&gt;
&lt;p&gt;&lt;span style=&quot;font-size:120%;&quot;&gt;&lt;span style=&quot;color:#970118&quot;&gt;&lt;strong&gt;人类学家&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
