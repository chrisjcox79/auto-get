&lt;/div&gt;
&lt;div class=&quot;left-grid&quot;&gt;
&lt;div class=&quot;image-container floatleft&quot;&gt;&lt;img src=&quot;http://scp-jp.wdfiles.com/local--files/hal-aki-achievement-badges/%E5%AE%9F%E7%B8%BE_%E7%94%9F%E7%89%A9%E5%AD%A6%E8%80%85.png&quot; width=&quot;50&quot; alt=&quot;%E5%AE%9F%E7%B8%BE_%E7%94%9F%E7%89%A9%E5%AD%A6%E8%80%85.png&quot; class=&quot;image&quot; /&gt;&lt;/div&gt;
