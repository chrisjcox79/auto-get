&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/mscarlet&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=1745583&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610223149&quot; alt=&quot;MScarlet&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=1745583)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/mscarlet&quot;  &gt;MScarlet&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
