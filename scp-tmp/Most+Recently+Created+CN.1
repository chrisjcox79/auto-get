&lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/twilit&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6592438&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248003&quot; alt=&quot;Twilit&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6592438)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/twilit&quot;  &gt;Twilit&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
