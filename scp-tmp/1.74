div#container-wrap {
    background-image: url(http://scp-wiki.wikidot.com/local--files/theme:skiesmadestrange/body_bg.png);
}

#header h2 span {
    color: transparent;
    text-shadow: none;
}

#header h2 span::before {
    content: '在显得陌生的天穹';
    color: #efefef;
    text-shadow: 1px 1px 1px rgba(0,0,0,.8);
}
