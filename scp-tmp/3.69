<style>
/*
========================
书目样式
========================
*/

/* 通用 */
.memu-ch{
  margin: auto;
   height: auto;
  width: auto;
  overflow-y:auto;
  position: fixed;
  right: 2%;
  TOP: 50px;
        z-index: 2;/**/
    min-width:8rem

}

.fm-memu{
   text-align: right;
  margin: 0;
}

/* 书目 */
.memu-pg{

/*
height: 0;
width: 0;
opacity: 0;
*/
  border-radius: 10px;
  border:solid 1px #444444;
  float:none;
  padding:10px;
  box-shadow: 1px 2px 3px 0px #23334c;
  background:#ffffff ;
}

.memu-list p{
  font-size: 110%;
  margin: 0 20px 10px  10px;
}

.memu-list p:before{
  content: " ◎ ";
  color: #333;
}

.memu-list ul{
  list-style-type:circle;
   padding: 0 0 0 2rem ;
}

.memu-list ul:hover{
  list-style-type:disc;

}

.memu-list p:hover:before{
  content: " ▶ ";
  color: #333;
}

.fm-goto{
    margin: 0 0px 0px  5px;
}

.fm-goto-top:before{
    content: " ▲ ";
}

.fm-goto-bottom:before{
    content: " ▼ ";
}

.fm-goto-top:before,
.fm-goto-bottom:before {
   color: #555;
}

.fm-goto-top:hover:before,
.fm-goto-bottom:hover:before {
   color: #000;
}

/*
------------------------------------------
动作
------------------------------------------
*/

:not(#u-hide-memu):target ~ .memu-pg{
  height: auto;
 /* width: auto;*/
  opacity: 1;
  transition: all 1s ;
}

#u-close-memu,
#u-hide-memu,
#u-show-bar,
#u-nap-bar{
  display: none;
}

.hide-memu-tip{
  font-size: 0;
}

#u-hide-memu:target ~ .memu-pg  .hide-memu-tip{
  font-size: 100%;
}

#u-hide-memu:target ~ .memu-pg .hide-memu{
  font-size: 0;
}

#u-show-bar:target ~ .rate-bar{
  display: block;
}

#u-nap-bar:target ~ .rate-bar{
  display: none;
}

#u-hide-memu:target ~ .memu-pg{
  opacity:0;
  transition: opacity 1s ;
}

#u-hide-memu:target ~ .memu-pg:hover{
  height: auto;
/*  width: auto;*/
  opacity:1;
  transition: opacity 1s ;
}

#u-close-memu:target ~ .memu-pg{

  width: 0rem ;
  height:0rem;
  font-size: 0;

  opacity: 0;
  transition: all 2s ;

}

/*
-----------------------------------------
评分
-----------------------------------------
*/

.memu-ch .rate-bar .collapsible-block-link{
padding: 0 0.5rem;
}

.rate-num{
padding:1rem 0rem 0 1rem;
}

.rate-btn {
padding:0 0px 0 1rem;
}

.rate-num .btn{
   display: none;
}

.rate-btn .rate-points{
   display: none;
}

.rate-num  .rate-points{
border-radius: 5px ;
}

.rate-btn  .rateup{
border-left: solid 1px #633;
border-radius:5px 0 0 5px ;
}

/* 
----------------------------
普通目录 
----------------------------
*/

#u-in-phone .toc-in ul,
.toc-in  p{
 font-size: 120%;
 text-align: center;
  border: 5px double grey;
  padding: 5px;
 margin: 10px 4rem 0 4rem;
}

.toc-in  p:hover{
background: rgba(1,1,1,0.1);
}

#u-in-phone .toc-in ul{
  list-style-type:none;
 margin: 10px 5rem 0 5rem;
}

#u-in-phone  .collapsible-block {

    text-align: center;
}

#u-in-phone table{
  margin: 0 auto !important;
}

#u-in-phone{
 display: none;
}

#u-in-phone{
 display: none;
}

/* 
----------------------------
手机屏幕 
----------------------------
*/

@media (max-width: 479px) {    
.memu-ch{
 display: none;
}
  #u-in-phone{
 display: block;
}
}
</style>
