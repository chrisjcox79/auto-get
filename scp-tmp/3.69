<p><span style="white-space: pre-wrap;">[[include&#32;:scp-wiki-cn:component:bookshelf-shelf-top</span><br />
|trans=yes<br />
|list-shelf=3<br />
|book-annotation=2<br />
|my-plank=yes<br />
|plank-background=var(&#8212;bluepaper-image)<br />
|plank-filter=drop-shadow(4px 15px 5px #1f2a36)<br />
|plank-background-size=cover 100%<br />
|plank-border-radius=25px<br />
]]</p>
<p><span style="white-space: pre-wrap;">[[include&#32;:scp-wiki-cn:component:bookshelf-books</span><br />
|list-book=0<br />
|link-color=gold<br />
|book-link=链接地址<br />
|link-name=链接文本<br />
|book-info=注释在此<br />
|self-defining=true<br />
|self-book-color=#162c44<br />
|self-book-background=url(&quot;<a href="http://scpsandboxcn.wikidot.com/local--files/image/Bgr-WL-Blue.png">http://scpsandboxcn.wikidot.com/local--files/image/Bgr-WL-Blue.png</a>&quot;);<br />
|book-annotation=2<br />
|self-book-border=2px solid #320f79<br />
|self-link-color=red<br />
|self-description-color=<br />
|self-info-shadow=rgba(9,9,9,0.5)<br />
|self-info-background=rgba(9,9,9,0.5)<br />
|self-info-border=5px inset #333<br />
]]</p>
