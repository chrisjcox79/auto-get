<p>注释在此</p>
</div>
</div>
<div class="the-shelf-block"></div>
<div id="u-listbook-{$list-book}" class="dust-jacket cover-mix-2">
<div class="book-list link-white">
<p><a href="javascript:;">样式七 蓝紫</a></p>
</div>
</div>
<div class="book-description book-annotation-1">
