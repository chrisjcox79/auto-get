<div class="book-list link-gold">
<p><a href="javascript:;">样式三 绿典</a></p>
</div>
</div>
<div class="book-description book-annotation-1">
<p>注释在此</p>
</div>
<div class="float-info info-1 book-annotation-2">
<div class="info-under">
<p>注释在此</p>
</div>
</div>
<div class="the-shelf-block"></div>
<div id="u-listbook-{$list-book}" class="dust-jacket cover-black">
<div class="book-list link-white">
<p><a href="javascript:;">样式四 黑铁</a></p>
</div>
</div>
<div class="book-description book-annotation-1">
<p>注释在此</p>
</div>
<div class="float-info info-1 book-annotation-2">
<div class="info-under">
<p>注释在此</p>
</div>
</div>
<div class="the-shelf-block"></div>
<div id="u-listbook-{$list-book}" class="dust-jacket cover-galaxy">
<div class="book-list link-white">
