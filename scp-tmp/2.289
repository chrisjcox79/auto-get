    .text-part .risk-class {
        font-size: 0.9em;
    }

    .text-part > .main-class::after,
    .text-part .disrupt-class::after,
    .text-part .risk-class::after {
        height: 2rem;
        width: 2rem;
        top: -webkit-calc(50% - 1.25rem);
        top: -moz-calc(50% - 1.25rem);
        top: calc(50% - 1.25rem);
    }

    .text-part > .main-class::before,
    .text-part .disrupt-class::before,
    .text-part .risk-class::before {
        height: 2.5rem;
        width: 2.5rem;
        font-size: 1rem;
        top: -webkit-calc(50% - 1.25rem);
        top: -moz-calc(50% - 1.25rem);
        top: calc(50% - 1.25rem);
        right: 1.5rem;
    }

    .anom-bar-container.esoteric .text-part > .main-class::before,
    .anom-bar-container.机密 .text-part > .main-class::before,
    .anom-bar-container.機密 .text-part > .main-class::before {
        top: 0.15rem;
        width: 4.5rem;
        height: 2.5rem;
        right: 1rem;
        -webkit-background-size: 100% 100%;
           -moz-background-size: 100% 100%;
             -o-background-size: 100% 100%;
                background-size: 100% 100%;
        background-position: left -10px center;
    }

    .anom-bar-container.esoteric .text-part > .main-class::after,
    .anom-bar-container.机密 .text-part > .main-class::after,
    .anom-bar-container.機密 .text-part > .main-class::after {
        height: 2.5rem;
        width: 2.5rem;
    }

    .bottom-box > .diamond-part {
        position: absolute;
        top: 0;
        right: 0;
        width: 40vw;
        height: 40vw;
        padding: 0;
    }

    .diamond-part * {
        background-repeat: no-repeat;
    }

    .top-box .top-left-box {
        -ms-grid-row: 2;
        -ms-grid-column: 1;
    }

    .top-box .top-center-box {
        -ms-grid-row: 3;
        -ms-grid-column: 1;
    }

    .top-box .top-right-box {
        -ms-grid-row: 4;
        -ms-grid-column: 1;
    }

    .anom-bar-container.pending .anom-bar > .bottom-box,
    .anom-bar-container.等待分级 .anom-bar > .bottom-box,
    .anom-bar-container.等待分級 .anom-bar > .bottom-box,
    .anom-bar-container.neutralized .anom-bar > .bottom-box,
    .anom-bar-container.无效化 .anom-bar > .bottom-box,
    .anom-bar-container.無效化 .anom-bar > .bottom-box,
    .anom-bar-container.explained .anom-bar > .bottom-box,
    .anom-bar-container.已解明 .anom-bar > .bottom-box,
    .anom-bar-container.已解明 .anom-bar > .bottom-box {
        height: 6rem;
    }

    .danger-diamond > .top-icon {
        top: 0.375rem;
    }

    .danger-diamond > .right-icon {
        right: 0.375rem;
    }

    .danger-diamond > .left-icon {
        left: 0.375rem;
    }

    .danger-diamond > .bottom-icon {
        bottom: 0.375rem;
    }
}

@supports not (--css: variables) {

    .anom-bar {
        display: -webkit-box;
        display: -webkit-flex;
        display: -moz-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-orient: vertical;
        -webkit-box-direction: normal;
        -webkit-flex-flow: column nowrap;
           -moz-box-orient: vertical;
           -moz-box-direction: normal;
            -ms-flex-flow: column nowrap;
                flex-flow: column nowrap;
    }

    .anom-bar > .top-box {
        display: -webkit-box;
        display: -webkit-flex;
        display: -moz-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-box-direction: normal;
        -webkit-flex-direction: row;
           -moz-box-orient: horizontal;
           -moz-box-direction: normal;
            -ms-flex-direction: row;
                flex-direction: row;
        -webkit-flex-wrap: nowrap;
            -ms-flex-wrap: nowrap;
                flex-wrap: nowrap;
    }

    .top-box .top-center-box {
        -webkit-box-flex: 2;
        -webkit-flex-grow: 2;
           -moz-box-flex: 2;
            -ms-flex-positive: 2;
                flex-grow: 2;
    }

    .anom-bar > .bottom-box {
        display: -webkit-box;
        display: -webkit-flex;
        display: -moz-box;
        display: -ms-flexbox;
        display: flex;
    }

    .bottom-box > .text-part {
        -webkit-box-flex: 1;
        -webkit-flex-grow: 1;
           -moz-box-flex: 1;
            -ms-flex-positive: 1;
                flex-grow: 1;
        width: 100%;
    }

    .anom-bar-container .text-part .main-class {
        overflow: hidden;
    }

    .anom-bar-container .text-part .disrupt-class,
    .anom-bar-container .text-part .risk-class {
        display: -webkit-box;
        display: -webkit-flex;
        display: -moz-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-box-direction: normal;
        -webkit-flex-direction: row;
           -moz-box-orient: horizontal;
           -moz-box-direction: normal;
            -ms-flex-direction: row;
                flex-direction: row;
        -webkit-flex-wrap: nowrap;
            -ms-flex-wrap: nowrap;
                flex-wrap: nowrap;
        -webkit-box-align: center;
        -webkit-align-items: center;
           -moz-box-align: center;
            -ms-flex-align: center;
                align-items: center;
        -webkit-box-pack: start;
        -webkit-justify-content: flex-start;
           -moz-box-pack: start;
            -ms-flex-pack: start;
                justify-content: flex-start;
    }

    .anom-bar-container .text-part .disrupt-class .class-category,
    .anom-bar-container .text-part .risk-class  .class-category {
        -webkit-flex-shrink: 4;
            -ms-flex-negative: 4;
                flex-shrink: 4;
    }

    .bottom-box > .diamond-part {
        width: 6rem;
        height: 6rem;
        -webkit-box-flex: 0;
        -webkit-flex-grow: 0;
           -moz-box-flex: 0;
            -ms-flex-positive: 0;
                flex-grow: 0;
        -webkit-flex-shrink: 0;
            -ms-flex-negative: 0;
                flex-shrink: 0;
        display: -webkit-box;
        display: -webkit-flex;
        display: -moz-box;
        display: -ms-flexbox;
        display: flex;
    }

@media (max-width: 480px ) {
        .anom-bar > .top-box {
            height: 6rem;
            display: -webkit-box;
            display: -webkit-flex;
            display: -moz-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-orient: vertical;
            -webkit-box-direction: normal;
            -webkit-flex-direction: column;
               -moz-box-orient: vertical;
               -moz-box-direction: normal;
                -ms-flex-direction: column;
                    flex-direction: column;
            -webkit-flex-wrap: nowrap;
                -ms-flex-wrap: nowrap;
                    flex-wrap: nowrap;
            width: -webkit-calc(100% - 40vw);
            width: -moz-calc(100% - 40vw);
            width: calc(100% - 40vw);
        }

        .top-box .top-left-box {
            display: initial;
        }

        .top-box > * {
            width: 100%;
            height: auto;
        }

        .top-box .top-center-box {
                -webkit-box-flex: 0;
                -webkit-flex-grow: 0;
                   -moz-box-flex: 0;
                    -ms-flex-positive: 0;
                        flex-grow: 0;
        }

    }
}

.lang-cn .lang-tr,
.lang-tr .lang-cn {
    display: none;
}
</style>
<style>
/* 文本栏 */
.contain-class .class-text {
    color: var(--class-color-1);
}

.disrupt-class .class-text {
    color: var(--class-color-2);
}

.risk-class .class-text {
    color: var(--class-color-3);
}

.anom-bar-container .text-part .main-class {
    background-color: var(--color-b-1);
    border-left: 0.5rem solid var(--color-a-1);
}

.anom-bar-container .text-part .disrupt-class {
    background-color: var(--color-b-2);
    border-left: 0.5rem solid var(--color-a-2);
}

.anom-bar-container .text-part .risk-class {
    background-color: var(--color-b-3);
    border-left: 0.5rem solid var(--color-a-3);
}

/* 图标栏 */

.anom-bar-container .danger-diamond > .top-icon::before {
    background-image: var(--icon-1-link);
    background-repeat: repeat-x;
    background-size: contain;
    background-color: var(--color-c-1);
}

.anom-bar-container .danger-diamond > .left-icon::before {
    background-image: var(--icon-2-link);
    background-repeat: repeat-x;
    background-size: contain;
    background-color: var(--color-c-2);
}

.anom-bar-container .danger-diamond > .right-icon::before {
    background-image: var(--icon-3-link);
    background-repeat: repeat-x;
    background-size: contain;
    background-color: var(--color-c-3);
}

.anom-bar-container .danger-diamond > .bottom-icon::before {
    background-image: var(--icon-4-link) !important;
    background-repeat: repeat-x;
    background-size: contain;
    background-color: var(--color-c-4);
}

.anom-bar-container .text-part > .main-class::before {
    background-image: var(--icon-1-link);
    background-repeat: repeat-x;
    background-color: var(--color-c-1);
}

.anom-bar-container .text-part > .main-class::after {
    background-image: var(--icon-4-link) !important;
    background-repeat: repeat-x;
    background-color: var(--color-c-4);
}

.anom-bar-container .text-part .disrupt-class::after {
    background-image: var(--icon-2-link);
    background-repeat: repeat-x;
    background-color: var(--color-c-2);
}

.anom-bar-container .text-part .risk-class::after {
    background-image: var(--icon-3-link);
    background-repeat: repeat-x;
    background-color: var(--color-c-3);
}

.anom-bar-container .text-part .disrupt-class::before {
    content: var(--level-2);
}

.anom-bar-container .text-part .risk-class::before {
    content: var(--level-3);
}

/* 机密条区 */

.anom-bar-container .top-right-box > .clearance::before {
    content: var(--level-1);
}

.anom-bar-container .top-center-box > div {
    background: var(--level-color);
}

.anom-bar-container .top-center-box > .bar-one {
    display: var(--cbar-1);
}

.anom-bar-container .top-center-box > .bar-two {
    display: var(--cbar-2);
}

.anom-bar-container .top-center-box > .bar-three {
    display: var(--cbar-3);
}

.anom-bar-container .top-center-box > .bar-four {
    display: var(--cbar-4);
}

.anom-bar-container .top-center-box > .bar-five {
    display: var(--cbar-5);
}

.anom-bar-container .top-center-box > .bar-six {
    display: var(--cbar-6);
}
</style>
<style>
.alpha {
--class-color-1: #593781;
--class-color-2: #593781;
--class-color-3: #593781;

--level-color: #593781;

--color-a-1: #593781;
--color-a-2: #593781;
--color-a-3: #593781;

--color-c-1: #593781;
--color-c-2: #593781;
--color-c-3: #593781;
--color-c-4: {$icon-bg-color-4};

--color-b-1: #C1ACFB;
--color-b-2: #C1ACFB;
--color-b-3: #C1ACFB;

--level-1: "[已编辑]";
--level-2: "N";
--level-3: "N";

--cbar-1: block;
--cbar-2: block;
--cbar-3: block;
--cbar-4: block;
--cbar-5: block;
--cbar-6: block;

--icon-1-link: url("http://scp-wiki.wikidot.com/local--files/component:anomaly-class-bar/pending-icon.svg");
--icon-2-link: url("http://ah-sandbox.wikidot.com/local--files/icons/brightness-icon.svg");
--icon-3-link: url("http://ah-sandbox.wikidot.com/local--files/icons/dangerous-icon.svg");
--icon-4-link: url("{$esoteric-icon}");

--secondary-class: {$secondary-class};
}
</style>
<style>
@import url('https://fonts.font.im/css?family=Quicksand');

.module-body {
    background-color: {$body-bg};
    color: {$body-color};
    height: calc(5em + 2px);
}

.text-1 p,
.text-2 p,
.text-3 p,
.text-4 p {
    margin: 0 !important;
    font-family: 'Quicksand', sans-serif;
}

.text-1 p,
.text-3 p {
    font-weight: bold;
    line-height: 1;
}

.text-2 p,
.text-4 p {
    line-height: 1.5;
}

.special-yes .special-no,
.special-no .special-yes {
    display: none;
}

.lang-cn .lang-tr,
.lang-tr .lang-cn {
    display: none;
}

/* LEFT-BAR */
.left-bar {
    height: 5em;
}

/* RIGHT-BAR */
.right-bar {
    position: relative;
    height: 5em;
    width: 14em;
    top: -5em;
    left: calc(100% - 14em);
}

.right-text {
    position: relative;
    top: calc(-5em - 2px);
    text-align: right;
}

.text-2::before {
    /* font-weight: bold; */
    font-family: 'Quicksand', sans-serif;
    line-height: 1.5;
}

.lang-cn .level-1 .text-2::before {
    content: "公开";
    font-size: 125%;
}

.lang-cn .level-2 .text-2::before {
    content: "保密";
    font-size: 125%;
}

.lang-cn .level-3 .text-2::before {
    content: "机密";
    font-size: 125%;
}

.lang-cn .level-4 .text-2::before {
    content: "最高机密";
    font-size: 125%;
}

.lang-cn .level-5 .text-2::before {
    content: "绝密";
    font-size: 125%;
}

.lang-cn .level-6 .text-2::before {
    content: "宇宙绝密";
    font-size: 125%;
}

.lang-tr .level-1 .text-2::before {
    content: "公開";
    font-size: 125%;
}

.lang-tr .level-2 .text-2::before {
    content: "保密";
    font-size: 125%;
}

.lang-tr .level-3 .text-2::before {
    content: "機密";
    font-size: 125%;
}

.lang-tr .level-4 .text-2::before {
    content: "最高機密";
    font-size: 125%;
}

.lang-tr .level-5 .text-2::before {
    content: "絕密";
    font-size: 125%;
}

.lang-tr .level-6 .text-2::before {
    content: "宇宙絕密";
    font-size: 125%;
}

.level-6 .text-2::before {
    content: {$clearance-name};
    font-size: 125%;
}

/* CLEARANCES */
.clearance div {
    box-size: border-box;
}

.clearance div div {
    border-left: solid 1px white;
    border-left: solid 1px {$body-bg};
}

.clear-6 {
    position: relative;
    top: 0em;
    left: 0em;
    width: calc(6em + 1px);
    height: 5em;
    /* margin: 0 auto; */
    transform: skewX(-10deg);
    border: solid 1px black;
    border: solid 1px {$clearance-border-color};
    display: block !important;
}

.clear-0 {
    display: none;
}

.clear-1 .bar-2,
.clear-1 .bar-3,
.clear-1 .bar-4,
.clear-1 .bar-5,
.clear-1 .bar-6 {
    display: none;
}

.clear-2 .bar-3,
.clear-2 .bar-4,
.clear-2 .bar-5,
.clear-2 .bar-6 {
    display: none;
}

.clear-3 .bar-4,
.clear-3 .bar-5,
.clear-3 .bar-6 {
    display: none;
}

.clear-4 .bar-5,
.clear-4 .bar-6 {
    display: none;
}

.clear-5 .bar-6 {
    display: none;
}

.bar-1 {
    position: relative;
    top: 0;
    left: 0;
    width: 1em;
    height: 5em;
    border-left: none !important;
    background-color: lemonchiffon;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}

.bar-2 {
    position: relative;
    top: -5em;
    left: 1em;
    width: 1em;
    height: 5em;
    background-color: khaki;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}

.bar-3 {
    position: relative;
    top: -10em;
    left: 2em;
    width: 1em;
    height: 5em;
    background-color: gold;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}

.bar-4 {
    position: relative;
    top: -15em;
    left: 3em;
    width: 1em;
    height: 5em;
    background-color: orange;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}

.bar-5 {
    position: relative;
    top: -20em;
    left: 4em;
    width: 1em;
    height: 5em;
    background-color: orangered;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}

.bar-6 {
    position: relative;
    top: -25em;
    left: 5em;
    width: 1em;
    height: 5em;
    background-color: firebrick;
    background-color: {$clearance-background-color};
    margin: 0 !important;
}
</style>
<style>
.left-div {
    position: relative;
    left: calc(50% - 2em);
    height: 2em;
    width: 2em;
    margin: 0;
    transform: skewY(45deg);
/*    border-bottom: solid 1px white;
    box-size: border-box; */
}

.right-div {
    position: relative;
    top: -2em;
    left: 50%;
    height: 2em;
    width: 2em;
    margin: 0;
    transform: skewY(-45deg);
    margin-bottom: -2em;
/*    border-bottom: solid 1px white;
    box-size: border-box; */
}
</style>
<style>
.left-div {
    position: relative;
    left: calc(50% - 2em);
    height: 2em;
    width: 2em;
    margin: 0;
    transform: skewY(45deg);
