    box-size: border-box; */
}
</style>
<style>
.infobox {
 display:inline-box;
 overflow:hidden;
 position:fixed;
 right: 1em;
 bottom: 2em;
 width: 21%;
 width: calc(50vw - 520px);
 min-width: 250px;
 height:23%;
 padding:1%;
 float:top; 
 box-shadow: 0px 4px 8px 0 rgba(0, 0, 0, 0.2), 0px 6px 20px 0 rgba(0, 0, 0, 0.19);
 background-color:#ffffff;
 opacity: 1;
 transition: all 0.5s ease-out;
}

.infobox:hover {
  color:rgba(0, 0, 0, 0.5);
  background-color:rgba(255, 255, 255, 0.5);
}

.preview{
 color:grey;
 width:100%;
 display: inline-block;
 padding-left:1%;
 transition: box-shadow 1s ease-out;
}

.preview:hover{
 box-shadow: 0px 4px 10px 0 rgba(0, 0, 0, 0.19);
 transition: box-shadow 0.3s ease-out;
}

.preview.yes:hover, .preview.true:hover{
  background: url('http://scpsandboxcn.wikidot.com/local--files/asriel3/logo.png') 80% 50% fixed no-repeat;
}

.preview .span { 
 opacity: 0;
 pointer-events: none;
 transition: all 0.3s ease-in-out;
 overflow:hidden;
 text-overflow:ellipsis;
 position:fixed;
 z-index: 11;
 right: 1em;
 bottom: 2em;
 width:21%;
 width: calc(50vw - 520px);
 min-width: 250px;
 height:23%;
 padding:1%;
 float:top; 
 color:grey;
 text-size:0.9em;
 font-family:微软细黑, Segoe UI Light,Verdana,sans-serif;
}

.preview:hover .span { 
 opacity: 1;
 background-color:#ffffff;
}

.collab-header{
 display:none;
}

.imagepre{
 background:#fff;
 max-width:19%;
 max-height:40%;
 position:fixed;
 right: 2em;
 bottom:calc(23% + 3em);
 box-shadow: 0px 4px 8px 0 rgba(0, 0, 0, 0.2), 0px 6px 20px 0 rgba(0, 0, 0, 0.19);
}

.imagepre.\{\$image\} {
display:none
}

.translation.\{\$translation\} {
display:none
}

.sortbar.no{
display:none
}

@media screen and (max-width:992px) {
    .preview .span{
        display: none;
    }
    .infobox {
        position: relative;
        margin: 1em auto;
        right: 0;
        bottom: 0;
        height: 9em;
    }
}

#page-options-container {
 background: transparent;
 position: relative;
 z-index: 10;
}

#action-area { position: relative; z-index: 20; }
</style>
<style>
.page-rate-widget-box {
    margin-right: 0em;
}

.rate-points::before {
    content: "只给你Down的" !important;
}

.rateup.btn{
    display:none
}

/* YUI TABS, FROM SCP-5002 */
.yui-navset .yui-nav .selected a em, .yui-navset .yui-nav a em{
padding: 0.25em .75em;
top: 0px;
margin-bottom: 0px
}

.yui-navset .yui-nav .selected a {
background: grey;
}

.yui-navset .yui-nav .selected {
margin: 0px;
}

.yui-navset .yui-nav .selected a, .yui-navset .yui-nav .selected a:focus, .yui-navset .yui-nav .selected a:hover, .yui-navset .yui-nav .selected a {
background: grey;
}

.yui-navset .yui-nav a, .yui-navset .yui-navset-top .yui-nav a {
background-color: none;
background-image: none;
}

.yui-navset .yui-nav a {
background: none;
}

.yui-navset .yui-nav li{
margin: 0px;
}

.yui-navset .yui-content {
background-color: #FFF;
}

/* LINKS, FROM TABOO */
.colorfullink a *,
#page-title,
#main-content h1 {
    background: linear-gradient(to right, red, orange, green, cyan, blue, violet);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

#page-title {
    display: none;
}

