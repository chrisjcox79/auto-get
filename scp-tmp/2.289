/* Mobile Media Query */
@media (max-width: 479px) { 
.left-grid,
.right-grid {
    width: 100%;
    float: left;
}
}

/* Note Media Query */
@media (min-width: 480px) and (max-width: 580px) { 
.left-grid,
.right-grid {
    width: 100%;
    float: left;
}
}

/* Tablet Media Query */
@media (min-width: 768px) and (max-width: 979px) {
.left-grid,
.right-grid {
    width: 100%;
    float: left;
