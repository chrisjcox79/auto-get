@media (max-width: 960px ) {
    .anom-bar > .top-box {
        padding-bottom: 1.5em;
    }

    .anom-bar > .bottom-box {
        -ms-grid-columns: 1fr 0.5rem 6rem;
        grid-template-columns: 1fr 6rem;
        height: 6rem;
    }

    .anom-bar-container.esoteric .text-part > .main-class > .contain-class > .class-text, .anom-bar-container.机密 .text-part > .main-class > .contain-class > .class-text, .anom-bar-container.機密 .text-part > .main-class > .contain-class > .class-text, .text-part > .disrupt-class > .class-text, .text-part > .risk-class > .class-text {
        font-size: -webkit-calc( 18px + (24 - 18) * ( (100vw - 400px) / ( 960 - 300) ));
        font-size: -moz-calc( 18px + (24 - 18) * ( (100vw - 400px) / ( 960 - 300) ));
        font-size: calc( 18px + (24 - 18) * ( (100vw - 400px) / ( 960 - 300) ));
    }

