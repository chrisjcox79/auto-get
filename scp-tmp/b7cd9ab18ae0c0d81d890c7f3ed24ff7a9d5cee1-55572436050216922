<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html id="html-block-html" xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en"><head><meta http-equiv="Content-type" content="text/html; charset=utf-8"/><link rel="stylesheet" href="/common--theme/base/css/html-block.css"/></head><body>

<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>修改代码，右边会自动显示结果</title>
<!--适应移动端-->
<meta name="viewport" content="width=device-width, initial-scale=1">
<!--css样式-->
<style>
    body{background-color: #ffffff}
    .aaa{background-color: #ffffff;padding: 10px;display: block}
</style>
<!--引用jquery库-->
<script src="https://libs.baidu.com/jquery/1.11.3/jquery.min.js"></script>
</head>

<body>

<div class="aaa">
    加入购物车
</div>

<script type="text/javascript">
    $(document).ready(function(){
          //点击
       $(".aaa").click(function(){
     alert("商品已售罄: )");
       });
       //悬停到目标上
       $(".aaa").mouseover(function(){
     $(this).css("background-color","#FF8C38");
       });
       //悬停离开
       $(".aaa").mouseout(function(){
     $(this).css("background-color","#ffffff");
       });
    });
</script>

<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body>
</html>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body></html>