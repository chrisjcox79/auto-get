div#side-bar div.side-block {
    border: none;
    border-radius: 10px;
    box-shadow:0 2px 6px rgba(20,0,62,0.4);
}
#side-bar a:visited {
    color: #3366AA !important;
}
a:visited {
    color: #335588 !important;
}
a{
    color: #3366AA !important;
}
#side-bar .heading {
    color: #BBF;
    border-bottom: solid 1px #BBF;
    padding-left: 15px;
    margin-bottom: 5px;
    font-size: 8pt;
    font-weight: bold;
}
#side-bar .side-block {
    border: 2px solid blue;
    box-shadow: 6px 4px 6px #000cd3;
    background-color: rgba(10, 00, 31, 0.46) !important;
}
h1, #page-title {
    color: #4169E1;
    padding: 0 0 0.25em;
    margin: 0 0 0.6em;
    font-weight: normal;
    border-color: #191970;
}
#footer {
    clear: both;
    font-size: 77%;
    background: rgba(44, 44, 44, 0) !important;
    color: #bbb;
    margin-top: 15px;
    padding: 3px 10px;
}
body {
    background-color: #FFFFFF;
    font-size: 0.80em;
    color: #1C86EE;
}
blockquote {
    background:rgba(70, 130, 240, 0.12);
    box-shadow: 1px -1px 5px rgb(5,79,218),
                       -1px 1px 3px rgba(81, 117, 214, 0.9);
    border:0px solid #00bcd4;
}

a.collapsible-block-link {
    font-weight: bold; 
}

/* LINKS */
a {
    color: var(--fg-light);
    text-decoration: bold;
    background: transparent;
}

a.newpage {
    color: var(--fg-light);
    text-decoration: bold;
    background: transparent;
}

#side-bar a:visited{ color: var(--fg-light); }

a:visited { color: var(--fg-light); }

/* INFO PANE */
.rate-box-with-credit-button {
    background-color: var(--fg-dark) !important;
    border-color: var(--fg-med-dark) !important;
    border-radius: 0px !important;
}

.page-rate-widget-box{
    border: none !important;
    border-radius: 0px !important;
}

.rate-box-with-credit-button .fa-info {
    border-color: var(--fg-med-dark) !important;
    color: var(--bg) !important;
}

.rate-box-with-credit-button .fa-info:hover {
    color: var(--fg-light) !important;
}

.rate-box-with-credit-button .cancel {
    border: none !important;
}

.close-credits{
    filter: hue-rotate(280deg);
}

.modalbox {
    box-shadow: 0px 1px 10px rgb(166,37,221,0.3) !important;
}

/* PAGE TITLEs */
h1, #page-title {
    color: var(--fg-dark-2);
}

/* TOP MENU */

#top-bar ul li ul {
    border: solid 1px var(--fg-muted-dark);
}

#top-bar ul li.sfhover a,
#top-bar ul li:hover a {
    background: var(--bg);
    color: var(--fg-muted-dark);
}

/* Custom page content classes */
.content-panel .panel-body {
    background: var(--bg);
}

body {
    background-color: #E6E6F4 !important;
}

.content-panel .panel-footer {
    color: var(--bg);
}

.content-panel .panel-footer a {
    color: var(--bg);
}

/* Standard Image Block */
.scp-image-block {
    border: solid 1px var(--fg-muted-dark);
}

.scp-image-block .scp-image-caption {
    background-color: var(--bg);
    border-top: solid 1px var(--fg-muted-dark);
}

/* Wikiwalk Navigation */
.footer-wikiwalk-nav {
    font-weight: bold;
    font-size: 75%;
}

/* off-canvas */
@media (max-width: 767px) {
.open-menu a {
    border: 0.2em solid var(--fg-muted-dark) !important;
    color: var(--fg-muted-dark) !important;
}

#side-bar {
    background-color: rgb(192, 192, 192);
}

#side-bar:target + #main-content {
    left: 0;
}
}

@media (min-width: 768px) {
#header h1 a {
    font-size: 150%;
}
}
 /* wikidot page elements */
table.wiki-content-table th {
    background-color:rgba(17, 33, 230, 0.24);
    border: 1px solid rgb(61,89,171);
    padding: 0.3em 0.7em;
}
table.wiki-content-table td {
    border: 1px solid rgb(61,89,171);
    padding: 0.3em 0.7em;
}
/* Interwiki */
.scpnet-interwiki-frame {
    filter: hue-rotate(273deg) saturate(50%) brightness(111%);
}
</style>
<style>
.yui-navset.yui-navset-top {
    border-left: 3px solid #9aa7cf;
}
.yui-navset .yui-nav {
    position: relative;
    z-index: 0;
    border: none;
    padding-left: 0.2em;
}
.yui-navset .yui-nav li {
    padding: 0;
    margin: 0.2em 0.3em;
    transition: transform 0.2s ease-in-out;
}
.yui-navset .yui-nav li a {
    background: transparent;
    color: #5f6368;
    border: 1px solid rgba(0,0,0,0.12);
    transition: background 0.1s ease-in-out,
                color 0.1s ease-in-out,
                border 0.1s ease-in-out;
}
.yui-navset .yui-nav li a:hover {
    background: rgba(0,0,0,0.04);
    color: #202124;
    border: 1px solid rgba(0,0,0,0.12);
}
.yui-navset .yui-nav li a em {
    border: none;
    padding: 0.5em 0.5em calc(0.5em - 2px) 0.5em;
}
.yui-navset .yui-nav .selected {
    padding: 0;
    margin: 0.2em 0.3em;
    transform: scale(1.1);
}
.yui-navset .yui-nav .selected a, .yui-navset .yui-nav .selected a:focus, .yui-navset .yui-nav .selected a:hover {
    padding: 0;
    border: 1px solid #9aa7cf;
    border: 1px solid var(--dark-accent);
    background: #295183;
    background: var(--light-accent);
    color: #9aa7cf;
    border: 1px solid;
}
.yui-navset .yui-nav .selected a em {
    padding: 0.5em 0.5em calc(0.5em - 2px) 0.5em;
    border: none;
}

.yui-navset .yui-content {
    display: flex;
    flex-direction: column;
    background-color: transparent;
    border: none;
    padding: 0;
    position: relative;
    margin-top: 0.2em;
    transform-origin: 0 0;
}
.yui-navset .yui-content > div {
    border: 1px solid rgba(0,0,0,0.12);
    border-left: none;
    background-color none;
    padding: 0.25em 0.5em;
    display: block;
    top: 0;
    overflow: hidden;
    transform-origin: 0 0;
}
#page-content .yui-navset .yui-content > div > * {
    transform-origin: 0 0;
}
#page-content .yui-navset .yui-content > div[style*="none"] {
    display: block !important;
    flex: 0;
    max-height: 0;
    padding: 0 0.5em;
    border-width: 0;
    /* The following transition affects the one that DISAPPEARS */
    transition: padding 0s linear 0.5s,
                border-width 0s linear 0.5s,
                flex 0.5s cubic-bezier(.0,1.27,.0,.89) 0s;
    animation: tab-disappear 0.5s ease-in-out 0s 1 both;
}
#page-content .yui-navset .yui-content > div[style*="block"] {
    display: block !important;
    flex: 1;
    max-height: 9999rem;
    /* The following transition affects the one that APPEARS */
    transition: padding 0s linear 0.5s,
                border-width 0s linear 0.5s,
                flex 0.5s cubic-bezier(.99,.0,.99,.0) 0.5s;
    animation: tab-appear 0.5s ease-in-out 0.5s 1 both;
}

@keyframes tab-disappear {
    0% { max-height: 9999rem; }
    1% { max-height: 100vh; }
    100% { max-height: 0; }
}
@keyframes tab-appear {
    0% { max-height: 0; }
    99% { max-height: 100vh; }
    100% { max-height: 9999rem; }
}

table.wiki-content-table td {
    /* rgba is useless here */
    border-color: #e1e1e1;
}
table.wiki-content-table th {
    border-color: #e1e1e1;
    background-color: #f5f5f5;
}
#header {
    height: 140px;
    position: relative;
    z-index: 10;
    padding-bottom: 22px; /* FOR MENU */
    background: url(http://recks-cn.wikidot.com/local--files/component:theme/logo2.png) 10px 40px no-repeat;
    background-size: 95px 100px ;
}
    #login-status * {
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
    }

    #login-status {
        min-height: -webkit-calc(var(--base-font-size) * 1.5);
        min-height: -moz-calc(var(--base-font-size) * 1.5);
        min-height: calc(var(--base-font-size) * 1.5);
        border: .0625rem solid rgb(var(--bright-accent));
        -webkit-border-radius: .0625rem;
        -moz-border-radius: .0625rem;
        border-radius: .0625rem;
        -webkit-border-radius: var(--border-radius-width);
        -moz-border-radius: var(--border-radius-width);
        border-radius: var(--border-radius-width);
        color: rgba(200, 100, 50, 0.5);
        background-color: #424248;
        background-color: rgb(var(--gray-monochrome));
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
        -webkit-box-flex: 1;
        -webkit-flex-grow: 1;
        -moz-box-flex: 1;
        -ms-flex-positive: 1;
        flex-grow: 1;
    }

    #login-status .printuser {
        position: relative;
        top: 0;
        left: 0;
        color: rgb(var(--swatch-text-light));
        border-right: .0625rem solid rgb(var(--bright-accent));
        background: rgb(var(--swatch-primary-darkest));
        -webkit-box-shadow: none;
        -moz-box-shadow: none;
        box-shadow: none;
        padding: 0.25rem;
        margin: 0;
        font-weight: 900 !important;
    }

    #login-status .printuser a {
        width: 0.75em;
    }

    #login-status #my-account {
        color: rgb(var(--black-monochrome));
    }

    #login-status #account-topbutton {
        border: initial;
        padding: 0.5em 0.5em 0.5em 0.25em;
        position: relative;
        height: 100%;
        top: 0;
        left: 0;
        margin: 0;
        font-size: 1em;
    }

body {
    font-family: Montserrat,华文细黑,sans-serif;
}

