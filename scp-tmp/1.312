<td style="width: 10%; text-align: center;"><span class="fa fa-microphone"><span style="white-space: pre-wrap;">&nbsp;</span></span></td>
<td style="text-align: center;">
<div class="talk" style="background-color: #EEEEEE; width: 85%; max-width: none; font-size: medium;">
<div style="float: right; display: inline-block; color: #303060;">
<p>‪‪<span class="fa fa-user-circle"><span style="white-space: pre-wrap;">&nbsp;</span></span></p>
</div>
<div style="display: inline-block; color: #BBBBBB;">
<p>Aa</p>
</div>
