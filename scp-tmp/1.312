    width: 100%;
    height: .25em;
    background: -webkit-linear-gradient(315deg,transparent,transparent 45%,#f00,transparent 55%,transparent 100%),-webkit-linear-gradient(45deg,transparent,transparent 45%,#f00,transparent 55%,transparent 100%);
