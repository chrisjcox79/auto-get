<div class="content-panel standalone series">
<div style="text-align: right;">
<div class="collapsible-block">
<div class="collapsible-block-folded"><a class="collapsible-block-link" href="javascript:;">+&nbsp;评分</a></div>
<div class="collapsible-block-unfolded" style="display:none">
<div class="collapsible-block-unfolded-link"><a class="collapsible-block-link" href="javascript:;">-&nbsp;评分</a></div>
<div class="collapsible-block-content">
<p><iframe src="http://scp-wiki-cn.wikidot.com/short-stories:00074/?theme_url=http://scp-wiki-cn.wdfiles.com/local--code/log-of-anomalous-items-cn:_theme/1" align="" frameborder="0" height="" scrolling="no" width="" class="" style="width:100%;height:26px;overflow:hidden"></iframe></p>
</div>
