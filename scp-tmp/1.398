<div style="text-align: right;">
<p><span id="u-credit-00110" class="option-button fa fa-info-circle">信息</span><a class="option-button fa fa-edit" href="/short-stories:00110" target="_blank">编辑 &amp; 评论</a></p>
</div>
<div id="u-credit-00110-hovertip">
