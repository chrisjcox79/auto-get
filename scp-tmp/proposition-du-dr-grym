                    <div id="page-content">
                        

<div style="text-align: right;">
<div class="heritage-emblem"><a href="/heritage-collection-arc"><img src="http://scp-wiki-cn.wdfiles.com/local--files/component:heritage-rating/scp-heritage-v3.png" alt="scp-heritage-v3.png" class="image" /></a></div>
