<div class="collapsible-block-content">
<div class="scp-image-block block-center" style="width:100%;"><img src="http://scp-wiki-cn.wdfiles.com/local--files/fragment:1252-02/52-2.png" style="width:100%;" alt="52-2.png" class="image" />
