day = 28;
}

if (hrs < 10 ){
var hrs = "0" + hrs;
}

if (min < 10 ){
var min = "0" + min;
}

date ="【" + day + " "+ sss + " "+ yr +","+ " " + hrs  +":" + min ;
document.getElementById("timer").innerHTML= date;
}

</script>
