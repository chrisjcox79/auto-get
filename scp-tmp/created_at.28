				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/nirvana073" onclick="WIKIDOT.page.listeners.userInfo(6031220); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=6031220&amp;amp;size=small&amp;amp;timestamp=1610248117" alt="nirvana073" style="background-image:url(http://www.wikidot.com/userkarma.php?u=6031220)"/></a><a href="http://www.wikidot.com/user:info/nirvana073" onclick="WIKIDOT.page.listeners.userInfo(6031220); return false;" >nirvana073</a></span> <span class="odate time_1598235039 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">24 Aug 2020 02:10</span>
