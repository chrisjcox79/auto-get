&lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/sears&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=3385230&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610248386&quot; alt=&quot;Sears&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=3385230)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/sears&quot;  &gt;Sears&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
