    border: 1px solid #999;
    background-color: #F7F7F7;
    padding: 5px 10px;
    font-size: 100%;
    font-weight: bold;
}

.DummyForumTitle{
padding-top: 0.5em; /* Firefox bug? ←I don't know :-P*/
