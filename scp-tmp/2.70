    background-repeat: repeat-x,repeat-x;
}

tt {
    font-family: verdana,arial,helvetica,sans-serif;
    font-size: 1em;
    display: inline-table;
    text-align: center;
    white-space: nowrap;
    line-height: 1;
    height: 1em;
