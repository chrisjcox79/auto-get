span.animation-1::after {
    animation: animation-1 20s forwards;
    -webkit-animation: animation-1 20s forwards;
    content: "包含在数个基金会存储器上的异常模因，造成对应的相关信息被逐渐替换为员工玩笑或意外的文本缺失";
    animation-delay: 4s;
    -webkit-animation-delay: 4s;
}

span.animation-2::after {
    animation: animation-2 20s forwards;
    -webkit-animation: animation-2 20s forwards;
    content: "一切未经授权的访问行为";
    animation-delay: 4s;
    -webkit-animation-delay: 4s;
}

