<tr>
<td><span style="font-size: 125%;"><span style="font-weight: 900;">項目編號：</span>SCP-4190</span></td>
<td style="text-align: right;"><span style="font-weight: 900; font-size: 125%;">等級 2/4190</span></td>
</tr>
<tr>
<td><span style="font-size: 125%;"><span style="font-weight: 900;">收容等級：</span>SAFE</span></td>
<td style="text-align: right;"><span style="font-weight: 900; font-size: 125%;">受限</span></td>
