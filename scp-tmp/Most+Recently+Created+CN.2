&lt;div&gt;&lt;a class=&quot;fa fa-info&quot; href=&quot;#u-credit-view&quot;&gt;&lt;img src=&quot;http://scp-jp-sandbox2.wikidot.com/local--files/nav:side/blank.png&quot; title=&quot;Show Info&quot; style=&quot;position:absolute;height:100%;width:100%;top:0;left:0;&quot; alt=&quot;blank.png&quot; class=&quot;image&quot; /&gt;&lt;/a&gt;&lt;/div&gt;
