                        <div id="page-title">
                            GoI-1995-DE 「奇物室」(Das Wunderkabinett)
                        </div>
                    

                    

                    



                    <div id="page-content">
                        



<script type="text/javascript" src="https://d3g0gp89917ko0.cloudfront.net/v--3e3a6f7dbcc9/common--javascript/yahooui/tabview-min.js">
</script>
<div id="wiki-tabview-62706229d27da498f10b70c5a61bb8aa" class="yui-navset">
<ul class="yui-nav">
<li class="selected"><a href="javascript:;"><em>概觀</em></a></li>
<li><a href="javascript:;"><em>奇物室的成員</em></a></li>
<li><a href="javascript:;"><em>產品</em></a></li>
<li><a href="javascript:;"><em>文件</em></a></li>
