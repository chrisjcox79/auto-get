s=&quot;textbox&quot;]]</span><br /> 浮动文本<br /> <span style="white-space: pre-wrap;">[[/div]]</span></p> </blockquote> <p>此外，可以使用更少或更多的 <em>text-item</em> div 元素（推荐最多不超过 4 个）。</p> <blockquote> <p><span style="white-space: pre-wrap;">[[include&#32;:scp-wiki-cn:theme:paperstack]]</span><br /> <span style="white-space: pre-wrap;">&#32;</span><br /> <span style="white-space: pre-wrap;">[[div&#32;class=&quot;logo&quot;]]</span><br /> <span style="white-space: pre-wrap;">[[image&#32;http://scp-wiki.wdfiles.com/local--files/theme%3Apaperstack/lgtrans.png]]</span><br /> <span style="white-space: pre-wrap;">[[/div]]</span><br /> <span style="white-space: pre-wrap;">&#32;</span><br /> <span style="white-space: pre-wrap;">[[&gt;]]</span><br /> <span style="white-space: pre-wrap;">[[module&#32;Rate]]</span><br /> <span style="white-space: pre-wrap;">[[/&gt;]]</span><br /> <span style="white-space: pre-wrap;">&#32;</span><br /> <span style="white-space: pre-wrap;">[[div&#32;class=&quot;header-container&quot;]]</span><br /> <span style="white-space: pre-wrap;">[[div&#32;class=&quot;text-item&quot;]]</span><br /> <span style="white-space: pre-wrap;">文本</span><br /> <span style="white-space: pre-wrap;">[[/div]]</span><br /> <span style="white-space: pre-wrap;">[[/div]]</span></p> </blockquote> <div class="scp-image-block block-center" style="width:100%;"><img src="http://scp-wiki.wdfiles.com/local--files/theme%3Apaperstack/t1.png" style="width:100%;" alt="t1.png" class="image" /> <div class="scp-image-caption" style="width:100%;"> <p>1 个 <em>text-item</em> div 元素。</p> </div> </div> <p><span style="white-space: pre-wrap;">&#32;</span></p> <div class="scp-image-block block-center" style="width:100%;"><img src="http://scp-wiki.wdfiles.com/local--files/theme%3Apaperstack/t3.png" style="width:100%;" alt="t3.png" class="image" /> <div class="scp-image-caption" style="width:100%;"> <p>3 个 <em>text-item</em> div 元素。</p> </div> </div> <p><span style="white-space: pre-wrap;">&#32;</span></p>