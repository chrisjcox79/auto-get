&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/miku1314&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=4546338&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610198999&quot; alt=&quot;miku1314&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=4546338)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/miku1314&quot;  &gt;miku1314&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
