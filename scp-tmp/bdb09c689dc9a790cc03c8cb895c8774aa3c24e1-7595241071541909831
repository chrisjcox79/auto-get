<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html id="html-block-html" xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en"><head><meta http-equiv="Content-type" content="text/html; charset=utf-8"/><link rel="stylesheet" href="/common--theme/base/css/html-block.css"/></head><body>
<style>
body{
text-align: center;
font-family: '等线';
}
p{
width:400px;
margin-left:auto;
margin-right:auto;
text-align:center;
background:url("http://scpsandboxcn.wikidot.com/local--files/you-havent-seen-this-sandbox/x.jpg") no-repeat;
background-color: #a9589e;
background-position-x:98%;
background-position-y:50%;
border-top: 2px solid white;
border-left: 2px solid white;
margin-bottom:0;
color:white;
}
input{
width:390px;
height:199px;
text-align:center;
}
div{
width:400px;
height:200px;
background:#bcbcbf;
border: 2px solid black;
border-top: 0;
border-left: 2px solid white;
margin-left:auto;
margin-right:auto;
}
button{
width:150px;
height:50px;
background: rgb(14, 12, 45);
color:rgb(255, 52, 131);
border: 2px solid #0f4566;
border-radius: 5px;
}
button:hover{
background: rgb(39, 6, 75);
color:rgb(1,245,252);
border: 2px solid rgb(195, 42, 158);
}
button:active, button:focus{
outline:none;
}

@media only screen and (max-width: 920px) {
p{
width:300px;
}

input{
width:290px;
height:149px;
}

div{
width:300px;
height:150px;
}
}
</style>
<body>
<p>新建窗口</p>
<div>
<input id="findme" placeholder="在此填写午夜梦境">
<div id="findme2" style="display:none;text-align:center;"><br><br><br><br>已发送。</div>
</div>
<br>
<button onclick="func()">发送</button>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body>
<script>
function func(){
document.getElementById("findme").style.display="none";
alert("已发送。");
}
</script>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body></html>