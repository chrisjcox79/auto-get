*/

/* GLOBAL WIDTH */
body {
    background-color: #f8f8f8;
    color: #0c0c0c;

    --bg: #e6e6e6;
    --key: black;
    --page-title: #eee;
    --footnote: #bd00a7;
    --fg-light: #5b2f8e;
    --fg-muted: #613c8b;
    --fg-medium: #593781;
    --fg-med-dark: #482c68;
    --fg-dark: #1e122b;
    --fg-dark-2: #160e20;
    --fg-muted-dark: #3e2659;
    --fg-grad-2: #523276;
    --fg-grad-3: #2f1d44;
}
 #container-wrap {
     background: url(http://scp-wiki.wdfiles.com/local--files/component%3Apataphysics-theme/pataphysics-header100.png) top left repeat-x !important;
}

/* CONTAINER */
#header {
    background-image: none;
}

#header #header-extra-div-1,
#header #header-extra-div-2,
#header #header-extra-div-3 {
    width: 6.250rem;
    height: 6.250rem;
    display: flex;
    position: absolute;
    left: 0.25rem;
    top: 2rem;
}

/*
LOGO
 Logo created by TSATPWTCOTTTADC, CSS spinner by Woedenaz
 Released under CC BY-SA 3.0
*/
#header #header-extra-div-1::before,
#header #header-extra-div-2::before,
#header #header-extra-div-3::before {
    content: "";
    width: 6.250rem;
    height: 6.250rem;
    position: absolute;
    background-repeat: no-repeat;
    background-position: center center;
    background-size: contain;
    flex: 1;
}

