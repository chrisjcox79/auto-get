<style>
div#container-wrap{
background: url(http://ja.scp-wiki.net/local--files/scp-2000-jp/black.png) top left repeat-x;
background-size:100px;
}
#html-body{
background-color:#000;
color:#FFF;
}
.scp-image-caption{
color:#333;
}
.hovertip .content{
color:#333;
}

:root{
--mecolor: #B0C4DE;
--youcolor: #FFFFFF;
}

#page-content .me{
position: relative;
float: right;
width: 75%;
max-width: 450px;
margin-bottom: 8px;
padding-right: 12px;
text-align: right;
white-space: nowrap;
}

#page-content .metalk{
background: var(--mecolor);
}

#page-content .you{
display: inline-block;
position: relative;
width: 75%;
max-width: 450px;
margin-bottom: 8px;
padding-left: 12px;
text-align: left;
white-space: nowrap;
vertical-align: top;
}

#page-content .youtalk{
background: var(--youcolor);
}

#page-content .talk{
display: inline-block;
max-width: 75%;
white-space: normal;
color: #000000;
text-align: left;
padding: 6px 11px;
vertical-align: bottom;
}

.talk p{
margin: 0;
}

.me::after{
content: "";
right: -18px;
position: absolute;
transform: rotate(-30deg);
height: 0;
width: 0;
border-top: 5px solid transparent;
border-bottom: 5px solid transparent;
border-right: 20px solid transparent;
border-left: 20px solid var(--mecolor);
}

.you::before{
content: "";
left: -18px;
position: absolute;
transform: rotate(30deg);
height: 0;
width: 0;
border-top: 5px solid transparent;
border-bottom: 5px solid transparent;
border-right: 20px solid var(--youcolor);
border-left: 20px solid transparent;
}

#page-content .area{
height:500px;
width:330px;
position: absolute;
max-width: none;
font-family: verdana,arial,helvetica,sans-serif;
}

#page-content .mail{
color: #333333;
max-width:700px;
min-width:300px;
width:60vw;
position: absolute;
}

.top{
width:100%;
height: 50px;
color: #FFFFFF;
background-color: #4682B4;
border-collapse:collapse;
font-size: 150%;
}

.chat{
background-color: #DDDDDD;
padding-top: 10px;
height: 400px;
overflow-x: hidden;
overflow-y: scroll;
}

.bottom{
width:100%;
height: 50px;
color: #333333;
background-color: #FFFFFF;
border-collapse:collapse;
border: solid 1px;
font-size: 180%;"
}

