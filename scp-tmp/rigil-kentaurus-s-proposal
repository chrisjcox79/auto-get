<div class="scp-image-block block-center" style="width:100%;"><img src="http://scpsandboxcn.wdfiles.com/local--files/collab:rigil-kentaurus-001-ii/%E5%9C%B0%E7%82%B9-00%E5%A4%96%E6%99%AF.png" style="width:100%;" alt="地点-00外景.png" class="image" />
