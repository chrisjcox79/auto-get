<head>
<style>
.box div{
float:center;

text-align:center;
}
</style>

<script language="javascript">
window.setInterval('showTime()',1000);

function showTime()
{
var date;
var enabled = 0;
today = new Date();
var hours=today.getHours();
var min=today.getMinutes();
var sec=today.getSeconds();

if ( hours < 10 ){
 hours =  "0"+hours;
}

if (min < 10 ){
 min =  "0"+min;
}

if ( sec < 10 ){
 sec =  "0"+sec;
}

date =hours+":"+min+":"+sec;
document.getElementById("time").innerHTML=date;
}

</script>
</head>

<body onload="showTime()">
<p id="time" style="font-size:100%;"></p>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body>
