}
#page-content .licensebox22 .collapsible-block-folded .collapsible-block-link::before,
#page-content .licensebox22 .collapsible-block-unfolded .collapsible-block-link::before,
#page-content .licensebox22 .unfolded-collapse::before {
    display: none;
}
#page-content .licensebox22 .collapsible-block-content::after {
    display: none;
}
