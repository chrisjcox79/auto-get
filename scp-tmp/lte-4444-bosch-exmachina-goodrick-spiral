/* 加载图案 */

.goc-out{
        width: 500px;
       height:50em;
       padding-bottom: calc(100% / 1.5);
        text-align: center;
         font-family: '华文新魏';
}

    .goc-out:before{
        background-image: var(--gocLogo) ;
        background-size: contain;
         background-repeat: no-repeat;
       background-position: center;
     width: 100%;
        height:inherit;
       position: absolute;
        content: " ";
        top: 16em;
        left:0;
        z-index: -1;/*-1 可以当背景*/
        -webkit-filter: opacity(0.2);
        filter:opacity(0.2);
        margin:0 auto;
    }

.goc-in{
   margin:0 auto;
    padding: 0 auto;
   font-size: 150%;
   font-weight:bold;
   left:0;
   top: 18em;
   width: 100%;
   position: absolute;
}

.entry-1,.entry-2,.entry-3,.entry-4,.entry-5{
font-size: 0%;
opacity: 0;
}

.entry-1 {animation-delay: 2s;   -webkit-animation-delay:2s; }
.entry-2 {animation-delay: 6s;   -webkit-animation-delay:6s; }
.entry-3 {animation-delay: 12s; -webkit-animation-delay:12s; }
.entry-4 {animation-delay: 18s; -webkit-animation-delay:18s; }
.entry-5 {animation-delay: 24s; -webkit-animation-delay:24s; }

.record {
   -webkit-animation-name: record;
   animation-name: record-2;

   -webkit-animation-duration: 3s;
   animation-duration: 3s;
}

.record-2{
   -webkit-animation-name: record-2;
   animation-name: record-2;

   -webkit-animation-duration: 3s;
   animation-duration: 3s;

  -webkit-animation-iteration-count: infinite;
  animation-iteration-count: infinite;
}

@keyframes record {
   0% {opacity: 0;font-size: 100%;}
   25% {opacity: 1;font-size: 100%;}
   75% {opacity: 1;font-size: 100%;}
   100% {opacity: 0;font-size: 100%;}
}

@keyframes record-2 {
   0% {opacity: 0; font-size: 100%;}
   50% {opacity: 1;font-size: 100%;}
   100% {opacity: 0; font-size: 100%;}  
}
