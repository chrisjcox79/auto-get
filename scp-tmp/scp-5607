<div class="item1 CN">
<div class="itemnum CN">项目编号: SCP-5607</div>
<div class="objclass CN">
<div class="obj-left"></div>
<div class="obj-right Safe">
<div class="obj-text">Safe</div>
</div>
</div>
</div>
