<table style="width: 100%;">
<tr>
<td style="border-bottom: 1px solid #AAA; border-right: 1px solid #AAA; text-align: center; width: 25%;"><span style="font-size:90%;"><strong>指派站点</strong></span></td>
<td style="border-bottom: 1px solid #AAA; border-right: 1px solid #AAA; text-align: center; width: 25%;"><span style="font-size:90%;"><strong>站点主管</strong></span></td>
<td style="border-bottom: 1px solid #AAA; border-right: 1px solid #AAA; text-align: center; width: 25%;"><span style="font-size:90%;"><strong>首席研究员</strong></span></td>
