<style>
/*いつか調整します*/

@import url('http://dog-punch.wikidot.com/local--files/sintax:css-theme-arca/arca_back_normal');
@import url('https://fonts.googleapis.com/css2?family=Arapey&amp;family=Gentium+Basic&amp;display=swap');
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300&amp;display=swap');
@importn url('https://use.fontawesome.com/releases/v5.6.1/css/all.css');
.yui-navset .yui-nav a em, .yui-navset .yui-navset-top .yui-nav a em {
    border: solid #444;
    border-width: 1px 0 0;
    padding: 0.25em .75em;
    left: 0;
    right: 0;
    bottom: 0;
    top: -1px;
    position: relative;
}
/*ヘッダー*/
#header {
  text-align: center;
      background: none !important;
}
#header h1 {
  display: inline-block;
  position: absolute;
  left: 0;
  right: 0;
  margin: 0 auto;
  width: 100%;
}
#header h1 a {
  display: inline-block;
  left: 50%;
  padding: 100px 0px 25px;
  line-height: 0px;
  max-height: 0px;
  background: transparent;
  text-shadow: none;
}
#header h1 a::before:hover {
  opacity: 1;
}
#header h1 a span {
  display: none;
}
#header h1 a::before {
  content: "Tionscadal na Arca";
  color: #000;
  bottom: 0.5em;
  position: relative;
  white-space: nowrap;
  opacity: 0.6;
  font-family: 'Arapey','Noto Serif JP', serif;
  font-weight: 100;
  font-size: 180%;
  letter-spacing: 5px;
}
#header h2 {
  display: inline-block;
  position: absolute;
  bottom: 1em;
  left: 0;
  right: 0;
  margin: 0 auto;
  font-size: 300%
}
#header h2 span {
  font-size: 0px;
  padding: 5px;
}
#header h2:after {
  content: "Cuir i gcuimhne duit";
  padding: 22px 0;
  white-space: pre;
  font-family: 'Arapey','Noto Serif JP', serif;
  color: #000;
  opacity: 0.7;

}
/*画面ちっこいときのヘッダー*/
@media (max-width: 477px) {
#header h2 {
  font-size: 240% !important;
}
#header h1 a::before {
  font-size: 220%;
  opacity: 0.8;
}
#header h1 a::before {
  content: 'Pjt.Arca';
}
}
/*トップバー*/
#top-bar ul li.sfhover a,
#top-bar ul li:hover a {
    background: #fff !important;
    color: #292929 !important;
    opacity: 0.88 !important;
}
#top-bar ul li.sfhover a:hover,
#top-bar ul li:hover a:hover {
    background: #fff !important;
    text-decoration: none !important;
    opacity: 0.96 !important;
}

#top-bar a[href="javascript:;"],#top-bar a[href="/scp-international"] {
   background: none !important !important;
   color: #fff !important !important;
   opacity: 1 !important !impotrtant;
}
/*ログイン部分*/
/*#my-account {
  color: #000 !important;
}
#account-topbutton {
  border-radius: 2px;
  border: 1px solid #292929;
}*/
/*サイドバー*/
#side-bar a {
  transition: 1s;
  color: #4d4d4d;
  text-decoration: none;
}
#side-bar a:hover {
  color: #990040;
}
div#side-bar div.side-block {
  background: #fff !important;
  border-radius: 0px;
  border: none;
  box-shadow:1px 1px 5px -1px #000000;
  transition: 0.5s;
}
div#side-bar div.side-block:hover {
  box-shadow:1px 1px 8px -1px #000000;
}
#side-bar .heading {
  filter: grayscale(100%);
}

@media (max-width: 767px) {
#side-bar {
    background-color: #f5f5f5;
}
#side-bar:target .close-menu {
   background: none;
}
}
/*メインコンテンツ*/
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200&amp;display=swap');
/*タイトル*/
#page-title {
  color: #000;
  text-align: center;
  font-family: 'Arapey','Noto Serif JP', serif;
  font-size: 220%;
  transition: 0.5s;
  border-bottom: 1px solid #000;
  margin-top: -11px;
}
#page-title:hover {
  text-shadow:2px 2px 4px #292929;
}
/*うわー*/
h1 {
  color: #000;
}
table.wiki-content-table th {
  border: none;
  background: #292929;
  color: #fff;
}
table.wiki-content-table td {
  border: none;
}
table.wiki-content-table {
  border: 1px solid #292929;
}
a {
 color: #e3294e;
}
a.newpage {
  color: #e36429;
}
/*タブ*/
.yui-navset .yui-nav .selected a, .yui-navset .yui-nav .selected a:focus, .yui-navset .yui-nav .selected a:hover {
    background: #444;
    color: #fff;
    opacity: 1;
}
.yui-navset .yui-nav a, .yui-navset .yui-navset-top .yui-nav a {
    background: none;
    border:1px solid #444;
    border-width: 1px;
    color: #000;
    position: relative;
    text-decoration: none;
    transition: 1s;
}
.yui-navset .yui-nav .selected, .yui-navset .yui-navset-top .yui-nav .selected {
    margin: 0 0.16em 0.16em 0;
}
.yui-navset .yui-nav li, .yui-navset .yui-navset-top .yui-nav li {
    margin: 0 0.16em 0.16em 0;
}
div.yui-navset ul.yui-nav a:hover,
div.yui-navset ul.yui-nav a:focus {
    background: #444;
    color: #fff;
    opacity: 0.8;
}
.yui-navset .yui-content, .yui-navset .yui-navset-top .yui-content {
    border: none;
    border-top-color: #444;
    padding: 0.25em 0.5em;
    box-shadow:3px 3px 11px -5px #000;
}
.yui-navset .yui-content {
    background: #fff;
}
#page-options-container .btn{
   display: inline-block;
   padding: 5px;
   margin: 3px;
   color: #fff;
   background: #444;
   transition: 1s; 
   text-decoration: none;
   border: 1px solid #444;
   font-family: 'Arapey','Noto Serif JP', serif;
   letter-spacing: 4px;
   border-radius: 3px;
}
#page-options-container .btn:hover {
   background: #fff;
   color: #444;
   border: 1px solid #444;
}

#page-content .yui-navset .yui-content > div[style*="none"] {
   animation: tab-disappear 1s ease-in-out 0s 1 both;
   overflow: hidden;
}
#page-content .yui-navset .yui-content > div[style*="block"] {
   animation: tab-appear 1s ease-in-out 0s 1 both;
   overflow: hidden;
}
@keyframes tab-disappear {
    0% { max-height: 9999rem; }
    1% { max-height: 100vh; }
    100% { max-height: 0; }
}
@keyframes tab-appear {
    0% { max-height: 20px; }
    10% {max-height: 0px; }
    99% { max-height: 100vh; }
    100% { max-height: 9999rem; }
}
::selection {
  background: #ccc; 
  color: #333;
}
::-moz-selection {
    background: #ccc;
    color: #333;
}
.page-source {
    border: 1px solid #444;
    padding: 1em 2em;
}
.rateBox {
  filter: grayscale(100%);
}
div.page-rate-widget-box,
div.page-rate-widget-box span.rate-points,
div.page-rate-widget-box span.cancel {
    background-color: #444!important;
    border: solid #444 1px!important;
}
div.page-rate-widget-box span.rateup,
div.page-rate-widget-box span.ratedown {
    border: solid #444!important;
    border-width: 1px 0!important;
}
div.page-rate-widget-box span.rate-points,
div.page-rate-widget-box span.cancel a,
div.page-rate-widget-box span.cancel a:hover {
    color: #fff;
}
div.page-rate-widget-box span.rateup,
div.page-rate-widget-box span.ratedown {
    background-color: #fff!important;
}
div.page-rate-widget-box span.cancel a:hover,
div.page-rate-widget-box span.rateup a:hover,
div.page-rate-widget-box span.ratedown a:hover {
    background: #444 !important;
    color: #fff !important;
    border: none !important;
}
div.page-rate-widget-box span.rateup a,
div.page-rate-widget-box span.ratedown a {
    color: #444!important;
}
.page-rate-widget-box {
    border-radius: 0px;
}
.rate-box-with-credit-button .creditButton {
    background-color: #444;
    border: 1px solid #444;
    border-radius: 0px !important;
    filter: grayscale(100%);
}
.modalbox-title {
    background: #444;
}
.modalbox-title span {
    font-size: 0px;
}
.modalbox-title span:after {
    font-size: 30px !important;
    content: 'Credit';
    font-family: 'Arapey','Noto Serif JP', serif;
    color: #fff;
}
.modalbox .modalbox-title {
    background-color: #444 !important;
    border-radius: 0px !important;
}
.modalbox {
    background-color: #fff;
    border-radius: 0px !important;
    box-shadow: 0 2px 6px #000 !important;
    opacity: 0.85;
    transition: 1s;
}
.modalbox:hover {
    opacity: 0.97;
}
div[style="-moz-column-count:3"] span[style="color:#777"] {
    color: #000 !important;
    font-weight: bold;
    font-size: 110%;
}
body {
   animation:fade 3s ease-in 0.5s 1 both;
}
@media (max-width:600px) {
body {
   animation:fade 1s ease-in 0.5s 1 both;
}
}
@keyframes fade {
0% { opacity: 0; }
}
100% { opacity: 1; }
}
::-webkit-scrollbar-track {
    background: #f2f2f2;
}
::-webkit-scrollbar-thumb {
    background: #cccccc;
}
::-webkit-scrollbar {
    width: 14px;
    height: 9px;
    border: none;
}

/*ライセンス表記*/
/* Simple Theme */
/*by: 7happy7*/
/* CC BY-SA 3.0 */
/* http://topia.wikidot.com/component:simple */
#login-status {
    display: flex;
    flex-direction: column;
    align-content: space-around;
    font-size: 0;
    }
    #login-status .printuser {
        border: 1px solid #888;
        border-radius: 5px;
        margin: 0 0 .25rem;
        padding: 1px 1px 1px 5px;
        background-color: #444;
        }
        #login-status .printuser img.small {
            padding: 1px 2px 1px 8px;
    }
    #login-status [id] {
        font-size: .72rem;
    }
    #login-status > a[href="javascript:;"] {
        border: 1px solid #888;
        border-radius: 5px;
        font-size: 0;
        font-weight: bold;
        margin-left: 0;
        padding: 0 5px;
        text-align: center;
        text-decoration: none;
        background-color:#444;
        width: 21.8px;
    }
    #login-status > a[href="javascript:;"]:before {
        display: inline-block;
        font-family: FontAwesome;
        font-size: .72rem;
        margin: 4px 3px;
        text-rendering: auto;
        -webkit-font-smoothing: antialiased;
        transform: translate(0, 0);
    }
    #login-status #account-topbutton:before {
        content: "\f013";
    }
    #login-status .login-status-sign-in:before {
        content: "\f13e";
    }
    #login-status .login-status-create-account {
        margin: 0 0 .25rem;
    }
    #login-status .login-status-create-account:before {
        content: "\f067";
    }
    #login-status #my-account {
        display: none;
    }
    #login-status a strong {
        position: absolute;
        top: 0;
        right: 2.25rem;
        font-family: var(--bauhaus);
        font-size: 1rem;
        white-space: nowrap;
    }
    #login-status #account-topbutton:not(:focus):not(:focus-within):not(:hover):not(:active) + #account-options {
        display: none!important;
    }
    #header #login-status #account-topbutton + #account-options:focus,
    #header #login-status #account-topbutton + #account-options:focus-within,
    #header #login-status #account-topbutton + #account-options:hover,
    #header #login-status #account-topbutton + #account-options:active {
        display: block!important;
        }
        #account-options ul {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
            }
            #account-options ul > li {
                flex-grow: 1;
                text-align: center;
                width: 40%;
                }
                #account-options ul > li a {
                    transition: all 0.25s ease-in-out;
                }
                #account-options ul > li a:hover {
                    background-color: #444;
                    color: #fff;
                    text-decoration: none;
}
#login-status ul a {
  color: #444;
}
div#search-top-box {
