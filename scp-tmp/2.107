text-align: center;  
}

.page-tags:after  {
content: "点击边框以查看标签 \A \A";
margin: 40% ;
white-space: pre;
}

.page-tags:hover:after   {
content: " ";
}

@media (max-width: 479px) {    
.page-tags:after ,
.page-tags:before {
margin: 30% ;
}
}

.page-tags{
