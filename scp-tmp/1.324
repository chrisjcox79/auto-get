<div class="collapsible-block-content">
<blockquote>
<p>[[include :scpsandboxcn:svgheader1<br />
|lv=3<br />
|threat=绿<br />
|item=XXXX<br />
|oc=Euclid<br />
]]</p>
</blockquote>
<blockquote>
<p>[[include :scpsandboxcn:svgheader1<br />
|lv=6<br />
|threat=绿<br />
|item=XXXX<br />
|oc=Euclid<br />
<span style="color: red">|oc2=Thaumiel</span><br />
]]</p>
</blockquote>
<ul>
<li><strong>lv：</strong>0 - 6</li>
<li><strong>threat：</strong>白/蓝/绿/黄/橙/红/黑<br />
<span style="color: transparent"><strong>threat：</strong></span>white/blue/green/yellow/orange/red/black</li>
</ul>
</div>
</div>
</div>
<p><br /></p>
