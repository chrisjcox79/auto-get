[记录结束]

[[/div]]</code>
</pre></div>
</div>
</div>
</div>
<hr />
<p><strong><span style="text-decoration: underline;">选项3</span></strong><sup class="footnoteref"><a id="footnoteref-5" href="javascript:;" class="footnoteref" onclick="WIKIDOT.page.utils.scrollToReference('footnote-5')">5</a></sup></p>
