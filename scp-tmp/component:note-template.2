     height:12rem;
     padding:  0rem 0rem 0rem 0rem;
  }

  .shelf-yes .pager {
      writing-mode:   horizontal-tb  !important;  
      padding: 4rem 0 0 0;
      line-height: 2;
      width: calc(100% - 3rem);
  }

