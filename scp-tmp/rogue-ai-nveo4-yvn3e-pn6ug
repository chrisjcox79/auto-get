<tr>
<th colspan="2">NVEO4/YVN3E/PN6UG</th>
</tr>
<tr>
<th>状态</th>
<td>可回收</td>
</tr>
<tr>
<th>需求</th>
<td>高</td>
</tr>
<tr>
<th>价值</th>
<td>不出售</td>
