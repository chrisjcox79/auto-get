<tr>
<td><span style="font-size: 125%;"><span style="font-weight: 900; color: #ffb961">项目编号：</span>SCP-CN-1388</span></td>
<td style="text-align: right;"><span style="font-weight: 900; font-size: 125%; color: #ffb961">4/CN-1388级</span></td>
</tr>
<tr>
<td><span style="font-size: 125%;"><span style="font-weight: 900; color: #ffb961">收容等级：</span>Infinity∞</span></td>
<td style="text-align: right;"><span style="font-weight: 900; font-size: 125%; color: #ffb961;">太阳系外</span></td>
