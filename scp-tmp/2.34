<style>
@import url(http://scp-wiki-cn.wikidot.com/theme:spc/code/1);
#page-title { display: none; }
.feature-block {
    height: 230px;
}
.feature-block .panel-body {
    height: 160px;
    overflow-y: hidden;
}
.feature-block .feature-title {
    font-size: 120%;
    font-weight: bold;
}
.feature-block .feature-subtitle {
    font-size: 90%;
}

.feature-block .feature-title > p,
.feature-block .feature-subtitle > p {
    margin: 0;
}

.news-block .panel-body {
    padding: 0;
}
.news-block .panel-body .alternate {
    padding: 5px 10px;
}
.news-block .news-title {
    font-weight: bold;
    font-size: 110%;
    margin-bottom: 5px;
    color: #633;
}
.news-block .news-content {
    margin: 5px 0;
}
.news-block .news-title > p,
.news-block .news-content > p {
    margin: 0px !important;
    margin-block-start: 0em !important;
    margin-block-end: 0em !important;
}

.list-pages-item p {
    margin: 0px !important;
    margin-block-start: 0px !important;
    margin-block-end: 0px !important;
}

.spc-page-block .panel-body {
    padding: 0;
}
.spc-page-entry {
    padding: 5px 10px;
}
.spc-page-entry:nth-child(even),
.alternate:nth-child(even) {
    background-color: #fff;
    border-top: solid 1px #eeeee0;
    border-bottom: solid 1px #eeeee0;
}
.spc-page-entry div > p {
    margin: 0;
}
.spc-page-entry .spc-page-title {
    font-weight: bold;
    font-size: 110%;
}
.spc-page-entry .spc-page-title img {
    width: 16px;
    height: 11px;
    box-shadow: 0 1px 3px rgba(0,0,0,.5);
}
.spc-page-entry .spc-page-description {
    font-size: 90%;
    font-style: italic;
    margin: 5px 20px;
}
.spc-page-entry {
    margin: 5px 0;
    padding: 0px 0px 5px 0px;
}
.spc-page-footer {
    font-size: #333;
    font-size: 80%;
    margin: 5px 0;
}
.content-panel .panel-body {
    background: #fff9f0 url(http://www.scp-wiki.net/local--files/component:theme/panel-bg-gradient-reverse.png) bottom repeat-x;
    /* box-shadow: 1px 2px 3px rgba(0,0,0,.2) inset; */
}

.spc-page-entry table tr:nth-child(even){
    background-color: #fff;
}
</style>
