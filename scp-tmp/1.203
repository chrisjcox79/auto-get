.fade-in-words{
    width: 600px;
    margin: 0 auto;
    text-align: center;
}

/*自定义一个透明度从0到1的动画，它的名称是fade-in*/
@keyframes fade-in{  
    0%{ opacity: 0;}
    100%{opacity:1;}
}
@-webkit-keyframes fade-in{
    0%{ opacity: 0;}
    100%{opacity:1;}
}
@-ms-keyframes fade-in{
    0%{ opacity: 0;}
    100%{opacity:1;}
}
@-o-keyframes fade-in{
    0%{ opacity: 0;}
    100%{opacity:1;}
}
@-moz-keyframes fade-in{
    0%{ opacity: 0;}
    100%{opacity:1;}
}
.A{
    opacity: 0;      /*实先规定文字的状态是不显示的*/
    animation: fade-in 4s ease 0s 1;    /*调用名称为fade-in的动画，全程动画显示时间4S，进入方式为ease，延时0S进入，播放次数1次*/
    -webkit-animation: fade-in 4s ease 0s 1;
    -moz-animation: fade-in 4s ease 0s 1;
    -o-animation: fade-in 4s ease 0s 1;
    -ms-animation: fade-in 4s ease 0s 1;

    /*规定动画的最后状态为结束状态*/
    animation-fill-mode:forwards;
    -webkit-animation-fill-mode: forwards;  
      -o-animation-fill-mode: forwards;
      -ms-animation-fill-mode: forwards;   
      -moz-animation-fill-mode: forwards;
}
.B{
    opacity: 0;    
    animation: fade-in 4s ease 3s 1;
    -webkit-animation: fade-in 4s ease 3s 1;
    -moz-animation: fade-in 4s ease 3s 1;
    -o-animation: fade-in 4s ease 3s 1;
    -ms-animation: fade-in 4s ease 3s 1;

    /*规定动画的最后状态为结束状态*/
    animation-fill-mode:forwards;
    -webkit-animation-fill-mode: forwards;  
      -o-animation-fill-mode: forwards;
      -ms-animation-fill-mode: forwards;   
      -moz-animation-fill-mode: forwards;
}
.C{
    opacity: 0;    
    animation: fade-in 4s ease 6s 1;
    -webkit-animation: fade-in 4s ease 6s 1;
    -moz-animation: fade-in 4s ease 6s 1;
    -o-animation: fade-in 4s ease 6s 1;
    -ms-animation: fade-in 4s ease 6s 1;

    /*规定动画的最后状态为结束状态*/
    animation-fill-mode:forwards;
    -webkit-animation-fill-mode: forwards;  
      -o-animation-fill-mode: forwards;
      -ms-animation-fill-mode: forwards;   
      -moz-animation-fill-mode: forwards;
}
.D{
    opacity: 0;    
    animation: fade-in 4s ease 9s 1;
    -webkit-animation: fade-in 4s ease 9s 1;
    -moz-animation: fade-in 4s ease 9s 1;
    -o-animation: fade-in 4s ease 9s 1;
    -ms-animation: fade-in 4s ease 9s 1;

    /*规定动画的最后状态为结束状态*/
    animation-fill-mode:forwards;
    -webkit-animation-fill-mode: forwards;  
      -o-animation-fill-mode: forwards;
      -ms-animation-fill-mode: forwards;   
      -moz-animation-fill-mode: forwards;
}
.E{
    opacity: 0;    
    animation: fade-in 4s ease 12s 1;
    -webkit-animation: fade-in 4s ease 12s 1;
    -moz-animation: fade-in 4s ease 12s 1;
    -o-animation: fade-in 4s ease 12s 1;
    -ms-animation: fade-in 4s ease 12s 1;

    /*规定动画的最后状态为结束状态*/
    animation-fill-mode:forwards;
    -webkit-animation-fill-mode: forwards;  
      -o-animation-fill-mode: forwards;
      -ms-animation-fill-mode: forwards;   
      -moz-animation-fill-mode: forwards;
}
.F{
    opacity: 0;    
    animation: fade-in 4s ease 15s 1;
    -webkit-animation: fade-in 4s ease 15s 1;
    -moz-animation: fade-in 4s ease 15s 1;
    -o-animation: fade-in 4s ease 15s 1;
