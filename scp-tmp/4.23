    float: center;
    width: 286px;
    height: 315px;
    overflow: hidden;
    margin: 0 18px 18px 0;
    text-align: centre;
    background: #fff;
    position: relative;
    transition: all .2s;
}
.vehicle-example-item a .case-pad {
    width: 286px;
    height: 180px;
}
.vehicle-item-info {
    height: 135px;
    overflow: hidden;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    background: #fff;
    transition: all .2s;
}
