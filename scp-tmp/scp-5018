<div style="clear:both; height: 0px; font-size: 1px"></div>
<p><tt>group_info = ketrcont(sizeof(*group_info) + nblocks*sizeof(gid_t *), <span style="font-size:115%;">PSWRD_PHRASE = FALL</span>;</tt></p>
