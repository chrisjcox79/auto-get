</tr>
<tr>
<td style="border: 0;"><strong>剧本</strong>　　　　</td>
<td style="border: 0">Sal Linnen</td>
</tr>
<tr>
<td style="border: 0;"></td>
<td style="border: 0">和Roger Mackenzie</td>
</tr>
<tr>
<td style="border: 0;"><strong>原著</strong>　　　　</td>
<td style="border: 0">2007年<span style="color: #0645ad">Kate McGears</span>所著<span style="color: #0645ad">小说</span></td>
</tr>
<tr>
<td style="border: 0;"><strong>制片</strong>　　　　</td>
<td style="border: 0">2009 俄怀明州试演</td>
</tr>
<tr>
<td style="border: 0;"></td>
