					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/scorpion451" onclick="WIKIDOT.page.listeners.userInfo(1918720); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1918720&amp;amp;size=small&amp;amp;timestamp=1610204706" alt="Scorpion451" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1918720)"/></a><a href="http://www.wikidot.com/user:info/scorpion451" onclick="WIKIDOT.page.listeners.userInfo(1918720); return false;" >Scorpion451</a></span> <span class="odate time_1461681128 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">26 Apr 2016 14:32</span>
														</div>
