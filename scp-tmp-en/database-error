</tr>
<tr>
<td><span style="opacity:0.6">Jab, Mimi</span></td>
<td><span style="opacity:0.2">0</span></td>
<td><span style="opacity:0.6">2/2140</span></td>
</tr>
<tr>
<td><span style="opacity:0.8">Jake, Christian H.</span></td>
<td><span style="opacity:0.2">3</span></td>
<td><span style="opacity:0.8">2/2140</span></td>
</tr>
<tr>
<td>Jameson, Will</td>
<td>1</td>
<td>2/2140</td>
</tr>
<tr>
<td><span style="opacity:0.8">Jane, Augustine Maria</span></td>
<td><span style="opacity:0.2">2</span></td>
