&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/tl333s&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=1304786&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610204903&quot; alt=&quot;TL333s&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=1304786)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/tl333s&quot;  &gt;TL333s&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
