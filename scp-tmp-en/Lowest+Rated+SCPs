&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/iamthebushman&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=4748514&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610204908&quot; alt=&quot;IAmtheBushman&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=4748514)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/iamthebushman&quot;  &gt;IAmtheBushman&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
