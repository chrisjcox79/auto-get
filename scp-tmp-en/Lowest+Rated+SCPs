&lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/space-kaiser&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=5821360&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610204903&quot; alt=&quot;Space_Kaiser&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=5821360)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/space-kaiser&quot;  &gt;Space_Kaiser&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
