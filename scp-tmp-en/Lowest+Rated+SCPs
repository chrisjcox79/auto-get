&lt;div style=&quot;text-align: right;&quot;&gt;&lt;/div&gt;
&lt;div class=&quot;scp-image-block block-right&quot; style=&quot;width:300px;&quot;&gt;&lt;a href=&quot;http://scp-wiki.wdfiles.com/local--files/scp-5585/House&quot;&gt;&lt;img src=&quot;http://scp-wiki.wdfiles.com/local--resized-images/scp-5585/House/medium.jpg&quot; style=&quot;width:300px;&quot; alt=&quot;House&quot; class=&quot;image&quot; /&gt;&lt;/a&gt;
