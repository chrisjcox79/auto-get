&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/maskedn00b&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6796602&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610204904&quot; alt=&quot;MaskedN00B&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6796602)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/maskedn00b&quot;  &gt;MaskedN00B&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
