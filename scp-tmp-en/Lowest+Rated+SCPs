&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/alex-warbacher&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6639646&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610204904&quot; alt=&quot;Alex Warbacher&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6639646)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/alex-warbacher&quot;  &gt;Alex Warbacher&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
