				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/snorlison" onclick="WIKIDOT.page.listeners.userInfo(222125); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=222125&amp;amp;size=small&amp;amp;timestamp=1610182988" alt="snorlison" style="background-image:url(http://www.wikidot.com/userkarma.php?u=222125)"/></a><a href="http://www.wikidot.com/user:info/snorlison" onclick="WIKIDOT.page.listeners.userInfo(222125); return false;" >snorlison</a></span> <span class="odate time_1224911668 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">25 Oct 2008 05:14</span>
