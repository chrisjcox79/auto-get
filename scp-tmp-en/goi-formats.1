				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/greenwolf" onclick="WIKIDOT.page.listeners.userInfo(1814684); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1814684&amp;amp;size=small&amp;amp;timestamp=1610224031" alt="GreenWolf" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1814684)"/></a><a href="http://www.wikidot.com/user:info/greenwolf" onclick="WIKIDOT.page.listeners.userInfo(1814684); return false;" >GreenWolf</a></span> <span class="odate time_1487151232 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">15 Feb 2017 09:33</span>
