					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/kimura-okagawa" onclick="WIKIDOT.page.listeners.userInfo(398761); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=398761&amp;amp;size=small&amp;amp;timestamp=1610164270" alt="Kimura Okagawa" style="background-image:url(http://www.wikidot.com/userkarma.php?u=398761)"/></a><a href="http://www.wikidot.com/user:info/kimura-okagawa" onclick="WIKIDOT.page.listeners.userInfo(398761); return false;" >Kimura Okagawa</a></span> <span class="odate time_1273096734 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">05 May 2010 21:58</span>
														</div>
