					<span class="printuser anonymous"><a href="javascript:;" onclick="WIKIDOT.page.listeners.anonymousUserInfo('121.87.44.177'); return false;" ><img class="small" src="http://www.wikidot.com/common--images/avatars/default/a16.png" alt=""/></a><a href="javascript:;" onclick="WIKIDOT.page.listeners.anonymousUserInfo('121.87.44.177'); return false;" >Anonymous <span class="ip">(121.87.44.x)</span></a></span> <span class="odate time_1223466730 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">08 Oct 2008 11:52</span>
