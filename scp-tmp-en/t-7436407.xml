					<item>
				<guid>http://www.scpwiki.com/forum/t-7436407#post-4031349</guid>
				<title>(no title)</title>
				<link>http://www.scpwiki.com/forum/t-7436407/scp-002-ex#post-4031349</link>
				<description></description>
