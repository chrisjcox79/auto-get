    line-height: 1.25;
}

.obj-right > div {
    display: flex;
    flex-grow: 2;
    justify-content: center;
    width: calc(100% - 2.5rem);
    position: absolute;
    right: 0;
    font-size: 1.5em;
}

@media (max-width: 540px) {
    .class1 > div {
        font-size: 5.8vw;
        font-weight: bold !important;
    }

    .class1image {
        width: 3em;
    }

    .class1image img {
        height: 4rem;
    }

    .item1 > div {
        font-size: 4.2vw;
        line-height: 1.5;
    }

    .item1 > .itemnum {
        font-size: 1.5em !important;
    }

    .obj-right {
        background-position: -0.03em;
    }

    .obj-right > div {
        width: calc(100% - 2rem);
    }
}
