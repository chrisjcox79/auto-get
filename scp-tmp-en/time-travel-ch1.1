					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/ajmansfield" onclick="WIKIDOT.page.listeners.userInfo(2238949); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=2238949&amp;amp;size=small&amp;amp;timestamp=1610227276" alt="AJMansfield" style="background-image:url(http://www.wikidot.com/userkarma.php?u=2238949)"/></a><a href="http://www.wikidot.com/user:info/ajmansfield" onclick="WIKIDOT.page.listeners.userInfo(2238949); return false;" >AJMansfield</a></span> <span class="odate time_1491152555 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">02 Apr 2017 17:02</span>
