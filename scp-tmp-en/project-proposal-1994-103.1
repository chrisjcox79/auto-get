				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/stormbreath" onclick="WIKIDOT.page.listeners.userInfo(3075960); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3075960&amp;amp;size=small&amp;amp;timestamp=1610164616" alt="stormbreath" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3075960)"/></a><a href="http://www.wikidot.com/user:info/stormbreath" onclick="WIKIDOT.page.listeners.userInfo(3075960); return false;" >stormbreath</a></span> <span class="odate time_1510546341 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">13 Nov 2017 04:12</span>
