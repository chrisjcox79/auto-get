O&lt;/p&gt;
&lt;/blockquote&gt;
&lt;table class=&quot;wiki-content-table&quot;&gt;
&lt;tr&gt;
&lt;td&gt;&lt;em&gt;&lt;strong&gt;Hold Up! Remember the asterisks!&lt;/strong&gt;&lt;/em&gt;&lt;/td&gt;
&lt;/tr&gt;
