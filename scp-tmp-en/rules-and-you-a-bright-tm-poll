					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/mr-abadede" onclick="WIKIDOT.page.listeners.userInfo(3050072); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3050072&amp;amp;size=small&amp;amp;timestamp=1610251576" alt="Mr Abadede" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3050072)"/></a><a href="http://www.wikidot.com/user:info/mr-abadede" onclick="WIKIDOT.page.listeners.userInfo(3050072); return false;" >Mr Abadede</a></span> <span class="odate time_1499609752 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">09 Jul 2017 14:15</span>
