<style>
.enlarge{
transition: .25s;
}

.enlarge:hover{
transform: scale(1.6);
transition: .25s;
transition-delay: .4s;
z-index: 1000;
}
</style>
<style>
.unblur{
transition: .2s;
-webkit-filter: blur(12px);
filter: blur(12px);
}

.unblur:hover{
transition: .2s;
transition-delay: .1s;
-webkit-filter: blur(0.001px);
filter: blur(0.001px);
}
</style>
<style>
.fillpg {
    margin: auto;
    overflow: auto;
   -webkit-user-drag: none;
   -khtml-user-drag: none;
   -moz-user-drag: none;
   -o-user-drag: none;
   user-drag: none;
   -webkit-touch-callout: none;
   -webkit-user-select: none;
   -khtml-user-select: none;
   -moz-user-select: none;
   -ms-user-select: none;
   user-select: none;
}

.fillpg:hover{
    cursor: zoom-in;
}

.fillpg:active{
    background-color: #fff;
    height: 100% !important;
    width: auto !important;
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    margin: auto;
    overflow: auto;
    z-index: 200;
    outline: solid 10000px rgba(0,0,0,0.8);
    padding: none;
    cursor: zoom-out;
    object-fit: contain;
}
</style>
