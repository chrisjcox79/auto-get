-shadow: none;}#u-side-bar-0 ::-webkit-scrollbar-thumb {   background: rgba(250,240,250,0.6);   border-radius: 7px;   box-shadow: inset 0 0 4px rgba(60,60,60,0.4);}#u-side-bar-0 .error-block {display: none !important;padding: 1em;margin: 1em;border: 1px solid #FAA;}html {scroll-behavior: smooth;}.toc-box,.toc-box table,.toc-box table tbody,.toc-box table tbody tr,.toc-box table tbody tr td {width: 100%;margin: 0;padding: 0;}.toc-box table tbody tr td {display: table;}.toc-box #toc {display: table-cell;font-size: 90%;min-width: 80px;max-width: 210px;max-height: 300px;overflow-y: scroll;word-break: break-all;border: none!important;background-color: transparent;vertical-align: middle;}.toc-box #toc #toc-list {max-height: 300px!important;overflow-y: scroll;}.toc-box #toc #toc-action-bar,.toc-box #toc #toc-action-bar a {display: none!important;}.toc-box {margin: 0;padding: 0;display: table;}#u-side-bar-0 .toc-wrap .collapsible-block-unfolded-link {border-bottom: none;}#u-side-bar-0 .toc-wrap .collapsible-block-unfolded-link .collapsible-block-link {color: #b01;}@media (min-width: 768px) {.octool {height: 400px;overflow-y: scroll;overflow-x: visible;}.useful-pages {height: 300px;overflow-y: scroll;overflow-x: visible;}}@media (max-width: 1025px) {#u-side-bar-0 {width: 80%;position: relative;}#main-content {margin: 0 5%;}_::-webkit-full-page-media, _:future, :root #side-bar:hover + #main-content .close-window {visibility: visible;}#side-bar {cursor: pointer;display: block;position: fixed;width: 243px;height: 100%;overflow-y: auto;top: 0;left: -180px;z-index: 200;-webkit-transition:left 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-moz-transition:left 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-ms-transition:left 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-o-transition:left 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;transition:left 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;transition-duration: 0.7s;background-color: rgba(184, 134, 134, 0.01);visibility: hidden;-webkit-tap-highlight-color:rgba(0,0,0,0);}#side-bar .side-block {cursor: pointer;opacity: 0;-webkit-tap-highlight-color:rgba(0,0,0,0);}#side-bar:hover .side-block {opacity: 1;}#side-bar:hover {position: fixed;left: 0;z-index:200;background-color: rgba(184, 134, 134, 0.65);visibility: visible;}#side-bar:before {content: "";background-image: url(http://scp-jp.wdfiles.com/local--files/wiki-syntax%3Aside/sidebar-logo1_50px.png);position: fixed;display: block;left: 10px;bottom: 25px;width: 40px;height: 40px;transition-duration: 0.7s;visibility: visible;z-index:200;}#side-bar:hover:before {text-decoration: none !important;-webkit-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-moz-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-ms-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-o-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);visibility: hidden;border-radius: 50%;transition: all 0.5s ease 0.1s;transition-duration: 1s;}}@media (max-width: 1400px) {_::-webkit-full-page-media, _:future, :root #u-side-bar-0:hover + .close-window {visibility: visible;}#u-side-bar-0 {cursor:pointer;display: block;position: fixed;width: 229.6px;height: 100%;overflow-y: auto;top: 0;right: -180px;z-index: 200;-webkit-transition:right 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-moz-transition:right 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-ms-transition:right 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;-o-transition:right 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;transition:right 0.5s ease-in-out 0.1s, background-color 0.5s ease-in-out 0.1s;transition-duration: 0.7s;background-color: rgba(248,221,222,0.01);visibility: hidden;-webkit-tap-highlight-color:rgba(0,0,0,0);}#u-side-bar-0 .side-block {cursor: pointer;opacity: 0;-webkit-tap-highlight-color:rgba(0,0,0,0);}#u-side-bar-0:hover .side-block {opacity: 1;}#u-side-bar-0:hover {position: fixed;right: 0;z-index:200;background-color: rgba(248,221,222,0.6);visibility: visible;}#u-side-bar-0:before {content: "";background-image: url(http://unofficial-scp-sandbox-jp.wikidot.com/local--files/nav:side-tooltest/logosb3.png);position: fixed;display: block;right: 10px;bottom: 25px;width: 40px;height: 40px;transition-duration: 0.7s;visibility: visible;z-index:200;}#u-side-bar-0:hover:before {text-decoration: none !important;-webkit-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-moz-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-ms-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);-o-box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);box-shadow: 0px 0px 20px 3px rgba(153,153,153,1);visibility: hidden;border-radius: 50%;transition: all 0.5s ease 0.1s;transition-duration: 1s;}#u-side-bar-0 .side-block {padding: 1em;margin: 1em 0.5em;box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);}}.side-editing {font-size: 108%!important;font-weight: normal;color: rgba(165, 95, 115, 0.85);text-shadow: none!important;}.side-editing,a[name="page-top"][target] + div .ocbutton-wrap,a[name="page-top"][target] + div .ocbutton-wrap + .collapsible-block {display:none;}a[name="page-top"][target] + div .side-editing {display:block;}
