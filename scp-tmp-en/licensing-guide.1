			</div>
		</div>
		<div class="short">
							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,1656677)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,1656677)"></a> by <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/voct" onclick="WIKIDOT.page.listeners.userInfo(392303); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=392303&amp;amp;size=small&amp;amp;timestamp=1610180863" alt="Voct" style="background-image:url(http://www.wikidot.com/userkarma.php?u=392303)"/></a><a href="http://www.wikidot.com/user:info/voct" onclick="WIKIDOT.page.listeners.userInfo(392303); return false;" >Voct</a></span>, <span class="odate time_1355791249 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">18 Dec 2012 00:40</span>
