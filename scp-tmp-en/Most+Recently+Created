&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/r4-ex&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6519177&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610226471&quot; alt=&quot;R4_EX&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6519177)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/r4-ex&quot;  &gt;R4_EX&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
