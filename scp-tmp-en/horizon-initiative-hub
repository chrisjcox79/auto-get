<ul class="yui-nav">
<li class="selected"><a href="javascript:;"><em>Overview</em></a></li>
<li><a href="javascript:;"><em>Factions</em></a></li>
<li><a href="javascript:;"><em>Demographics</em></a></li>
<li><a href="javascript:;"><em>Relations</em></a></li>
<li><a href="javascript:;"><em>Activities</em></a></li>
