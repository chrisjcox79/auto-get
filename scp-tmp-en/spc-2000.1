					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/sirpudding" onclick="WIKIDOT.page.listeners.userInfo(348648); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=348648&amp;amp;size=small&amp;amp;timestamp=1610203727" alt="sirpudding" style="background-image:url(http://www.wikidot.com/userkarma.php?u=348648)"/></a><a href="http://www.wikidot.com/user:info/sirpudding" onclick="WIKIDOT.page.listeners.userInfo(348648); return false;" >sirpudding</a></span> <span class="odate time_1493871066 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">04 May 2017 04:11</span>
