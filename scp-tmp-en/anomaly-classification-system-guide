<h1 id="toc18"><span>Disruption Class Options<sup class="footnoteref"><a id="footnoteref-2" href="javascript:;" class="footnoteref" onclick="WIKIDOT.page.utils.scrollToReference('footnote-2')">2</a></sup></span></h1>
<div class="icons">
<div class="icon_container">
<div class="icon_image color-one"><img src="http://scp-wiki.wikidot.com/local--files/component:anomaly-class-bar/dark-icon.svg" alt="dark-icon.svg" class="image" /></div>
<div class="icon_name">dark</div>
</div>
<div class="icon_container">
<div class="icon_image color-two"><img src="http://scp-wiki.wikidot.com/local--files/component:anomaly-class-bar/vlam-icon.svg" alt="vlam-icon.svg" class="image" /></div>
