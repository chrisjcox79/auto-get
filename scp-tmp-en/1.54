    padding-right: 1em;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.class1 > div {
    color: #0c0c0c;
    font-family: rift, sans-serif, Arial, "游明朝", YuMincho, "ヒラギノ明朝 ProN W3", "Hiragino Mincho ProN", "HG明朝E", "ＭＳ Ｐ明朝", "ＭＳ 明朝", 'Noto Serif KR', serif;
