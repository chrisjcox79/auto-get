					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/thedeadlymoose" onclick="WIKIDOT.page.listeners.userInfo(732274); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=732274&amp;amp;size=small&amp;amp;timestamp=1610182421" alt="thedeadlymoose" style="background-image:url(http://www.wikidot.com/userkarma.php?u=732274)"/></a><a href="http://www.wikidot.com/user:info/thedeadlymoose" onclick="WIKIDOT.page.listeners.userInfo(732274); return false;" >thedeadlymoose</a></span> <span class="odate time_1429947966 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">25 Apr 2015 07:46</span>
