					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/tapeworms" onclick="WIKIDOT.page.listeners.userInfo(7203842); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=7203842&amp;amp;size=small&amp;amp;timestamp=1610247952" alt="Tapeworms" style="background-image:url(http://www.wikidot.com/userkarma.php?u=7203842)"/></a><a href="http://www.wikidot.com/user:info/tapeworms" onclick="WIKIDOT.page.listeners.userInfo(7203842); return false;" >Tapeworms</a></span> <span class="odate time_1610245611 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">10 Jan 2021 02:26</span>
																	<br/>
