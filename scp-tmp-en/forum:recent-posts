				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/granite-mask" onclick="WIKIDOT.page.listeners.userInfo(5147952); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=5147952&amp;amp;size=small&amp;amp;timestamp=1610200883" alt="Granite Mask" style="background-image:url(http://www.wikidot.com/userkarma.php?u=5147952)"/></a><a href="http://www.wikidot.com/user:info/granite-mask" onclick="WIKIDOT.page.listeners.userInfo(5147952); return false;" >Granite Mask</a></span> <span class="odate time_1610199155 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">09 Jan 2021 13:32</span>
																	<br/>
