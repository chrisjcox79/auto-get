							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,4044139)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,4044139)"></a> by <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/captainbacon" onclick="WIKIDOT.page.listeners.userInfo(3938198); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3938198&amp;amp;size=small&amp;amp;timestamp=1610203356" alt="CaptainBacon" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3938198)"/></a><a href="http://www.wikidot.com/user:info/captainbacon" onclick="WIKIDOT.page.listeners.userInfo(3938198); return false;" >CaptainBacon</a></span>, <span class="odate time_1540871078 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">30 Oct 2018 03:44</span>
		</div>
	</div>
 
                
        
                      
