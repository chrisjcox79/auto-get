				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/cybersqyd" onclick="WIKIDOT.page.listeners.userInfo(5336470); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=5336470&amp;amp;size=small&amp;amp;timestamp=1610204973" alt="cybersqyd" style="background-image:url(http://www.wikidot.com/userkarma.php?u=5336470)"/></a><a href="http://www.wikidot.com/user:info/cybersqyd" onclick="WIKIDOT.page.listeners.userInfo(5336470); return false;" >cybersqyd</a></span> <span class="odate time_1609759806 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">04 Jan 2021 11:30</span>
														</div>
