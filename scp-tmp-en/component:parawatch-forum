}

div#header h1 a span {
    /* hiding header text */
    font-size: 0px;
    color: transparent;
}

div#header h1 a:before {
    content: " ";
    color: rgb(24, 24, 24);
}

div#header h2 span {
    font-size:0px;
    padding: 4px;
}

div#header h2:after {
    content: " ";
