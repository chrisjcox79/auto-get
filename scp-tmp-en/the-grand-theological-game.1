				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/vaelynx" onclick="WIKIDOT.page.listeners.userInfo(914331); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=914331&amp;amp;size=small&amp;amp;timestamp=1610203958" alt="VAElynx" style="background-image:url(http://www.wikidot.com/userkarma.php?u=914331)"/></a><a href="http://www.wikidot.com/user:info/vaelynx" onclick="WIKIDOT.page.listeners.userInfo(914331); return false;" >VAElynx</a></span> <span class="odate time_1439220126 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">10 Aug 2015 15:22</span>
														</div>
