				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/zyn" onclick="WIKIDOT.page.listeners.userInfo(1404533); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1404533&amp;amp;size=small&amp;amp;timestamp=1610203958" alt="Zyn" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1404533)"/></a><a href="http://www.wikidot.com/user:info/zyn" onclick="WIKIDOT.page.listeners.userInfo(1404533); return false;" >Zyn</a></span> <span class="odate time_1439224034 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">10 Aug 2015 16:27</span>
