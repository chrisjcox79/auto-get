        top: 0.375rem;
    }

    .danger-diamond > .right-icon {
        right: 0.375rem;
    }

    .danger-diamond > .left-icon {
        left: 0.375rem;
    }

    .danger-diamond > .bottom-icon {
        bottom: 0.375rem;
    }
}

@supports not (--css: variables) {

