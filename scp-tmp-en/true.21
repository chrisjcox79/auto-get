                    flex-wrap: nowrap;
            width: -webkit-calc(100% - 40vw);
            width: -moz-calc(100% - 40vw);
            width: calc(100% - 40vw);
        }

        .top-box .top-left-box {
            display: initial;
        }

        .top-box > * {
            width: 100%;
            height: auto;
        }

        .top-box .top-center-box {
                -webkit-box-flex: 0;
                -webkit-flex-grow: 0;
