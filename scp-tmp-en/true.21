<div class="anom-bar-container item-5480 clear-2 safe {$secondary-class} vlam notice {$american}">
<div class="anom-bar">
<div class="top-box">
<div class="top-left-box"><span class="item">Item#:</span> <span class="number">5480</span></div>
<div class="top-center-box">
<div class="bar-one"></div>
