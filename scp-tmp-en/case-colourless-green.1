							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,2414470)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,2414470)">Just wondering...</a> by <span class="printuser deleted" data-id="2306764"><img class="small" src="http://www.wikidot.com/common--images/avatars/default/a16.png" alt=""/>(account deleted)</span>, <span class="odate time_1448715411 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">28 Nov 2015 12:56</span>
