				<div class="info">
					<span class="printuser deleted" data-id="2303803"><img class="small" src="http://www.wikidot.com/common--images/avatars/default/a16.png" alt=""/>(account deleted)</span> <span class="odate time_1499303306 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">06 Jul 2017 01:08</span>
														</div>
