					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/drmagnus" onclick="WIKIDOT.page.listeners.userInfo(318209); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=318209&amp;amp;size=small&amp;amp;timestamp=1610225809" alt="DrMagnus" style="background-image:url(http://www.wikidot.com/userkarma.php?u=318209)"/></a><a href="http://www.wikidot.com/user:info/drmagnus" onclick="WIKIDOT.page.listeners.userInfo(318209); return false;" >DrMagnus</a></span> <span class="odate time_1526566477 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">17 May 2018 14:14</span>
														</div>
