					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/wakawaaa" onclick="WIKIDOT.page.listeners.userInfo(5578352); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=5578352&amp;amp;size=small&amp;amp;timestamp=1610183616" alt="Wakawaaa" style="background-image:url(http://www.wikidot.com/userkarma.php?u=5578352)"/></a><a href="http://www.wikidot.com/user:info/wakawaaa" onclick="WIKIDOT.page.listeners.userInfo(5578352); return false;" >Wakawaaa</a></span> <span class="odate time_1594110866 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">07 Jul 2020 08:34</span>
														</div>
