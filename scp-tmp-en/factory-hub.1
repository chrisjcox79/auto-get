				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/moklin" onclick="WIKIDOT.page.listeners.userInfo(3009732); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3009732&amp;amp;size=small&amp;amp;timestamp=1610251162" alt="Moklin" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3009732)"/></a><a href="http://www.wikidot.com/user:info/moklin" onclick="WIKIDOT.page.listeners.userInfo(3009732); return false;" >Moklin</a></span> <span class="odate time_1510661529 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">14 Nov 2017 12:12</span>
