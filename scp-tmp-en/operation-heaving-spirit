<h1 id="toc1"><span>DEPT OF TACTICAL THEOLOGY</span></h1>
<hr />
<h2 id="toc2"><span>OPERATION HEAVING SPIRIT</span></h2>
<h3 id="toc3"><span>AFTER-ACTION REPORT</span></h3>
<hr /></div>
<script type="text/javascript" src="http://d3g0gp89917ko0.cloudfront.net/v--3e3a6f7dbcc9/common--javascript/yahooui/tabview-min.js">
