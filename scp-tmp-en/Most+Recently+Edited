&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/harryblank&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=6479803&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610249236&quot; alt=&quot;HarryBlank&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=6479803)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/harryblank&quot;  &gt;HarryBlank&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
