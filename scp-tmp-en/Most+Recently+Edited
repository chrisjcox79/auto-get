&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/darkstuff&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=1581620&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610249243&quot; alt=&quot;DarkStuff&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=1581620)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/darkstuff&quot;  &gt;DarkStuff&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
				<pubDate>Thu, 23 Jan 2020 03:01:57 +0000</pubDate>
												<content:encoded>
