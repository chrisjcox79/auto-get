alt="%E2%97%8F%E2%97%8F%7C%E2%97%8F%E2%97%8F%E2%97%8F%E2%97%8F%E2%97%8F%7C%E2%97%8F%E2%97%8F%7C%E2%97%8F" class="image" /></div> </div> </div> </div> <br /></div> <div style="background: black; padding: 1px 15px; border: ridge 5px gold; margin: 10px; border-radius: 30px 15px;"> <h2><span>Other Artworks</span></h2> <h4><span>Gifs ★</span></h4> <div class="collapsible-block"> <div class="collapsible-block-folded"><a class="collapsible-block-link" href="javascript:;">●-Foundation&nbsp;Gif1</a></div> <div class="collapsible-block-unfolded" style="display:none"> <div class="collapsible-block-unfolded-link"><a class="collapsible-block-link" href="javascript:;">○-Close</a></div> <div class="collapsible-block-content"> <div class="image-container aligncenter"><img src="http://scp-sandbox-3.wikidot.com/local--files/luxkeeper-s-artpage-v2/Foundation.gif" alt="Foundation.gif" class="image" /></div> </div> </div> </div> <div class="collapsible-block"> <div class="collapsible-block-folded"><a class="collapsible-block-link" href="javascript:;">●-MC&amp;D&nbsp;Ltd&nbsp;Gif</a></div> <div class="collapsible-block-unfolded" style="display:none"> <div class="collapsible-block-unfolded-link"><a class="collapsible-block-link" href="javascript:;">○-Close</a></div> <div class="collapsible-block-content"> <div class="image-container aligncenter"><img src="http://scp-sandbox-3.wikidot.com/local--files/luxkeeper-s-artpage-v2/Marshall%2C%20Carter%20%26%20Dark%20Ltd.gif" alt="Marshall%2C%20Carter%20%26%20Dark%20Ltd.gif" class="image" /></div> </div> </div> </div> <h4><span>Misc ¿</span></h4> <div class="collapsible-block"> <div class="collapsible-block-folded"><a class="collapsible-block-link" href="javascript:;">●-Pixel&nbsp;Egyptified&nbsp;SCP-049</a></div> <div class="collapsible-block-unfolded" style="display:none"> <div class="collapsible-block-unfolded-link"><a class="collapsible-block-link" href="javascript:;">○-Plague&nbsp;Doctor</a></div> <div class="collapsible-block-content"> <div 