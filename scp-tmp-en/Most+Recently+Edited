&lt;div class=&quot;level-text&quot;&gt;&lt;span class=&quot;base false EN&quot;&gt;2/4608&lt;/span&gt; LEVEL &lt;span class=&quot;base false EN&quot;&gt;2/4608&lt;/span&gt;&lt;/div&gt;
