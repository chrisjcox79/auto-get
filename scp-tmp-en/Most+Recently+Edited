&lt;div class=&quot;class1image&quot;&gt;&lt;img src=&quot;https://scp-wiki.wdfiles.com/local--files/component%3Aclassified-bar-woed-source/classified-lv2.svg&quot; alt=&quot;classified-lv2.svg&quot; class=&quot;image&quot; /&gt;&lt;/div&gt;
&lt;div class=&quot;item1 EN&quot;&gt;
