&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/drakimoto&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=5255688&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610162286&quot; alt=&quot;DrAkimoto&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=5255688)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/drakimoto&quot;  &gt;DrAkimoto&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
