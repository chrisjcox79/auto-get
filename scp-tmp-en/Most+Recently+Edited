&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/ralliston&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=5986843&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610224182&quot; alt=&quot;Ralliston&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=5986843)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/ralliston&quot;  &gt;Ralliston&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
