&lt;p&gt;&lt;iframe src=&quot;https://scp-wiki.wdfiles.com/local--code/info%3Astyle/2&quot; align=&quot;&quot; frameborder=&quot;&quot; height=&quot;&quot; scrolling=&quot;&quot; width=&quot;&quot; class=&quot;&quot; style=&quot;&quot;&gt;&lt;/iframe&gt;&lt;/p&gt;
