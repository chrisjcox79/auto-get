  </span><span class="hl-reserved">transform:</span><span class="hl-code"> translateX(-</span><span class="hl-number">50</span><span class="hl-string">%</span><span class="hl-code">)</span><span class="hl-code">;
  </span><span class="hl-reserved">font-family:</span><span class="hl-code"> 'Fira </span><span class="hl-string">Code</span><span class="hl-code">', </span><span class="hl-string">monospace</span><span class="hl-code">;
  </span><span class="hl-reserved">font-size:</span><span class="hl-code"> </span><span class="hl-number">1</span><span class="hl-code">rem</span><span class="hl-code">;
