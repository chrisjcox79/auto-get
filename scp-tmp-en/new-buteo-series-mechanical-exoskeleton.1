				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/othellothecat" onclick="WIKIDOT.page.listeners.userInfo(3213383); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3213383&amp;amp;size=small&amp;amp;timestamp=1610164608" alt="OthellotheCat" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3213383)"/></a><a href="http://www.wikidot.com/user:info/othellothecat" onclick="WIKIDOT.page.listeners.userInfo(3213383); return false;" >OthellotheCat</a></span> <span class="odate time_1538421248 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">01 Oct 2018 19:14</span>
														</div>
