.scp-hover-box::before {
    display: block;
    position: absolute;
    width: 100%;
    height: 100%;
    content: " ";
    box-sizing: content-box;
    top: 0;
    left: 0;
    transition: 
        border 1s 0.2s cubic-bezier(0.4, 0, 0.2, 1), 
        top 1s 0.2s cubic-bezier(0.4, 0, 0.2, 1), 
        left 1s 0.2s cubic-bezier(0.4, 0, 0.2, 1),
        background 1s 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

