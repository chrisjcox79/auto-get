					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/quikngruvn" onclick="WIKIDOT.page.listeners.userInfo(333389); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=333389&amp;amp;size=small&amp;amp;timestamp=1610251613" alt="Quikngruvn" style="background-image:url(http://www.wikidot.com/userkarma.php?u=333389)"/></a><a href="http://www.wikidot.com/user:info/quikngruvn" onclick="WIKIDOT.page.listeners.userInfo(333389); return false;" >Quikngruvn</a></span> <span class="odate time_1522433850 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">30 Mar 2018 18:17</span>
