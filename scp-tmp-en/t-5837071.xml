					<item>
				<guid>http://www.scpwiki.com/forum/t-5837071#post-3789424</guid>
				<title>To Be A Shark Or Not To Be A Shark?</title>
				<link>http://www.scpwiki.com/forum/t-5837071/spc-1057#post-3789424</link>
				<description></description>
				<pubDate>Thu, 03 May 2018 19:29:51 +0000</pubDate>
				<wikidot:authorName>Captain Kirby</wikidot:authorName>				<wikidot:authorUserId>3440103</wikidot:authorUserId>				<content:encoded>
