					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/doctor-cimmerian" onclick="WIKIDOT.page.listeners.userInfo(1414765); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1414765&amp;amp;size=small&amp;amp;timestamp=1610204976" alt="Doctor Cimmerian" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1414765)"/></a><a href="http://www.wikidot.com/user:info/doctor-cimmerian" onclick="WIKIDOT.page.listeners.userInfo(1414765); return false;" >Doctor Cimmerian</a></span> <span class="odate time_1486171026 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">04 Feb 2017 01:17</span>
														</div>
