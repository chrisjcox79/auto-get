					<![CDATA[
						 <blockquote> <p>//Apologies for the gimmick, but I couldn't resist.</p> <p>public String AuthorPost()<br /> {<br /> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;User[] critAttributions = {<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/thebillith" ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3042342&amp;amp;size=small&amp;amp;timestamp=1515949089" alt="TheBillith" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3042342)" /></a><a href="http://www.wikidot.com/user:info/thebillith" >TheBillith</a></span>, <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/captain-kirby" ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3440103&amp;amp;size=small&amp;amp;timestamp=1515949089" alt="Captain Kirby" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3440103)" /></a><a href="http://www.wikidot.com/user:info/captain-kirby" >Captain Kirby</a></span>, <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/cleverlyclearly" ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3566028&amp;amp;size=small&amp;amp;timestamp=1515949089" alt="CleverlyClearly" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3566028)" /></a><a href="http://www.wikidot.com/user:info/cleverlyclearly" >CleverlyClearly</a></span>, <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/stormbreath" ><img class="small" src="http://www.wikidot.com/avatar.php?userid=3075960&amp;amp;size=small&amp;amp;timestamp=1515949089" alt="stormbreath" style="background-image:url(http://www.wikidot.com/userkarma.php?u=3075960)" /></a><a href="http://www.wikidot.com/user:info/stormbreath" >stormbreath</a></span>};<br /> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;String authorCommentary = &quot;I've posted a new tale! I had it laying around in my sandbox, so I decided to tidy it up and make it into something workable. I plan on writing some more stuff in this setting eventually, maybe even get it made into a canon, so watch out for that!&quot;;<br /> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;String[] scpArticlesUsed = { &quot;<a href="http://www.scpwiki.com/scp-015">SCP-015</a>&quot;, &quot;<a href="http://www.scpwiki.com/scp-963">SCP-963</a>&quot;, &quot;<a href="http://www.scpwiki.com/scp-2000">SCP-2000</a>&quot; };<br /> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;String[] charactersUsed = { &quot;Doctor Jack Bright&quot; };<br /> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;return &quot;Thanks for reading!&quot;;<br /> }</p> </blockquote> <blockquote> <p><span style="white-space: pre-wrap;">///</span> &lt;<a href="https://www.youtube.com/watch?v=270W2ZPElaU">inspiration</a>&gt;<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;We were boarding the tall ships,<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;Eclipsing oblivion,<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;Deciding it all sang<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;A whole new significance.<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;It's made in the waiting,<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;afloat on a reservoir.<br /> <span style="white-space: pre-wrap;">///</span> &nbsp;It's borne us to form a start from an ending.<br /> <span style="white-space: pre-wrap;">///</span> &lt;/inspiration&gt;</p> </blockquote> 
				 	]]>
