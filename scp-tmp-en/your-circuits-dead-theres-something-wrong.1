					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/thefriendlyvandal" onclick="WIKIDOT.page.listeners.userInfo(2064544); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=2064544&amp;amp;size=small&amp;amp;timestamp=1610183123" alt="thefriendlyvandal" style="background-image:url(http://www.wikidot.com/userkarma.php?u=2064544)"/></a><a href="http://www.wikidot.com/user:info/thefriendlyvandal" onclick="WIKIDOT.page.listeners.userInfo(2064544); return false;" >thefriendlyvandal</a></span> <span class="odate time_1496975781 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">09 Jun 2017 02:36</span>
														</div>
