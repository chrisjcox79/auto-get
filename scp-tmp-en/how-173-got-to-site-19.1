					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/mrwrong" onclick="WIKIDOT.page.listeners.userInfo(2039383); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=2039383&amp;amp;size=small&amp;amp;timestamp=1610182408" alt="MrWrong" style="background-image:url(http://www.wikidot.com/userkarma.php?u=2039383)"/></a><a href="http://www.wikidot.com/user:info/mrwrong" onclick="WIKIDOT.page.listeners.userInfo(2039383); return false;" >MrWrong</a></span> <span class="odate time_1434591237 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">18 Jun 2015 01:33</span>
														</div>
