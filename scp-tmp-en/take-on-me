<div class="translation_block">
<h1 id="toc0"><span>Translations:</span></h1>
<div class="list-pages-box">    <div class="list-pages-item">


<p><iframe src="http://interwiki.scpdb.org/?wiki=scp-wiki&amp;lang=en&amp;page=_default:take-on-me" align="" frameborder="" height="" scrolling="" width="" class="" style=""></iframe></p>
</div>
    
    
    
    </div></div>
<div class="u-faq">
