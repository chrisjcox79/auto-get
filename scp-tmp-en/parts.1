					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/fieldstone" onclick="WIKIDOT.page.listeners.userInfo(1436137); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1436137&amp;amp;size=small&amp;amp;timestamp=1610182119" alt="fieldstone" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1436137)"/></a><a href="http://www.wikidot.com/user:info/fieldstone" onclick="WIKIDOT.page.listeners.userInfo(1436137); return false;" >fieldstone</a></span> <span class="odate time_1505964441 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">21 Sep 2017 03:27</span>
														</div>
