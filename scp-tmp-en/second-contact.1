					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/oboebandgeek99" onclick="WIKIDOT.page.listeners.userInfo(1782920); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1782920&amp;amp;size=small&amp;amp;timestamp=1610252513" alt="Oboebandgeek99" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1782920)"/></a><a href="http://www.wikidot.com/user:info/oboebandgeek99" onclick="WIKIDOT.page.listeners.userInfo(1782920); return false;" >Oboebandgeek99</a></span> <span class="odate time_1567567483 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">04 Sep 2019 03:24</span>
														</div>
