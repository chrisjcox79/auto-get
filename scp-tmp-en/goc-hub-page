<div class="yui-content">
<div id="wiki-tab-0-0">
<div class="image-container aligncenter"><a href="http://scp-wiki.wdfiles.com/local--files/goc-hub-page/GOC-Logo-v4.png"><img src="http://scp-wiki.wdfiles.com/local--resized-images/goc-hub-page/GOC-Logo-v4.png/medium.jpg" alt="GOC-Logo-v4.png" class="image" /></a></div>
