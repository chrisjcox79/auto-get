<body>
<span id="random_text"></span>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body>
<script src="http://scptestwiki.wdfiles.com/local--files/members%3Ascp-wt-woedcode-3/mersenne-twister.js "></script>
<script type="text/javascript">
if (localStorage.getItem("RandomID") === null) {
    var randomArray = [];
    var randomID = "";
    var alphabet = to_a();
    var symbol = ["/",".","|"]

    function to_a(c1 = 'a', c2 = 'z') {
            a = 'abcdefghijklmnopqrstuvwxyz'.split('');
            return (a.slice(a.indexOf(c1), a.indexOf(c2) + 1)); 
    }

    var m = new MersenneTwister();

    function generateId (num) {
        console.log("num=" + num);
        for (var i=0; i < num; i++) {
            var randNum = Math.floor(m.random(m.random() * 100) * 100); 
            var newNum;
            console.log("randNum=" + randNum);
            if (0 < randNum && randNum <= 20) {
                var n = new MersenneTwister(i);
                newNum = alphabet[Math.floor((n.random() * 25))];
            }
            if (21 < randNum && randNum <= 90) {
                var n = new MersenneTwister(i);
                newNum = Math.floor((n.random() * 10));
            }
            if (91 < randNum && randNum <= 99) {
                var n = new MersenneTwister(i);
                newNum = symbol[Math.floor((n.random() * 3))];
            }
            randomArray.push(newNum);
        }
        randomID =  randomArray.join("");
        return randomID;
    }
    document.addEventListener("DOMContentLoaded", function() {    
        localStorage.setItem("RandomID", generateId(20));
    });
}

document.getElementById("random_text").innerHTML = localStorage.getItem("RandomID"); 
</script>
<script type="text/javascript" src="/common--javascript/html-block-iframe.js"></script></body></html>