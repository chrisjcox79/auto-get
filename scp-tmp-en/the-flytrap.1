					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/anqxyr" onclick="WIKIDOT.page.listeners.userInfo(966960); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=966960&amp;amp;size=small&amp;amp;timestamp=1610225783" alt="anqxyr" style="background-image:url(http://www.wikidot.com/userkarma.php?u=966960)"/></a><a href="http://www.wikidot.com/user:info/anqxyr" onclick="WIKIDOT.page.listeners.userInfo(966960); return false;" >anqxyr</a></span> <span class="odate time_1331633707 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">13 Mar 2012 10:15</span>
														</div>
