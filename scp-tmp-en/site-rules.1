					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/drewbear" onclick="WIKIDOT.page.listeners.userInfo(301632); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=301632&amp;amp;size=small&amp;amp;timestamp=1610180866" alt="Drewbear" style="background-image:url(http://www.wikidot.com/userkarma.php?u=301632)"/></a><a href="http://www.wikidot.com/user:info/drewbear" onclick="WIKIDOT.page.listeners.userInfo(301632); return false;" >Drewbear</a></span> <span class="odate time_1381258741 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">08 Oct 2013 18:59</span>
														</div>
