.text-container-wrap {
  text-align:center;
  margin:auto;
  display:block;
  margin-top: 25px;
  width:400px;
  padding-top: 25px;
  border-radius:10px;
  border:3px solid #666;
  background-color:#fff;
  overflow:none;
  box-sizing:border-box;
  pointer-events:none!important;
  position:relative;
}

