</tr>
<tr>
<td style="border: 1px solid black; width: 15%; color: transparent;" rowspan="4">X</td>
<td style="border: 1px solid black; background-color: #EEE; width: 20%;">Psychic Resistance Scale</td>
<td style="border: 1px solid black; width: 20%;">
<div style="text-align: center;">
<p>92</p>
</div>
</td>
</tr>
<tr>
<td style="border: 1px solid black; background-color: #EEE; width: 20%;">Cognitive Resistance Value</td>
<td style="border: 1px solid black; width: 20%;">
<div style="text-align: center;">
<p>17.2</p>
</div>
</td>
