					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/petrograd" onclick="WIKIDOT.page.listeners.userInfo(455145); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=455145&amp;amp;size=small&amp;amp;timestamp=1610222987" alt="Petrograd" style="background-image:url(http://www.wikidot.com/userkarma.php?u=455145)"/></a><a href="http://www.wikidot.com/user:info/petrograd" onclick="WIKIDOT.page.listeners.userInfo(455145); return false;" >Petrograd</a></span> <span class="odate time_1479280336 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">16 Nov 2016 07:12</span>
														</div>
