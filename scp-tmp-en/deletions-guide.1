				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/communism-will-win" onclick="WIKIDOT.page.listeners.userInfo(617958); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=617958&amp;amp;size=small&amp;amp;timestamp=1610162217" alt="Communism will win" style="background-image:url(http://www.wikidot.com/userkarma.php?u=617958)"/></a><a href="http://www.wikidot.com/user:info/communism-will-win" onclick="WIKIDOT.page.listeners.userInfo(617958); return false;" >Communism will win</a></span> <span class="odate time_1332189200 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">19 Mar 2012 20:33</span>
														</div>
			</div>
			<div class="content" id="post-content-1397992">
									

