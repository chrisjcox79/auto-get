				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/ihp" onclick="WIKIDOT.page.listeners.userInfo(1267048); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1267048&amp;amp;size=small&amp;amp;timestamp=1610227328" alt="Ihp" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1267048)"/></a><a href="http://www.wikidot.com/user:info/ihp" onclick="WIKIDOT.page.listeners.userInfo(1267048); return false;" >Ihp</a></span> <span class="odate time_1595268612 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">20 Jul 2020 18:10</span>
														</div>
