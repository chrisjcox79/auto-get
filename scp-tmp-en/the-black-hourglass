				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/caspian2" onclick="WIKIDOT.page.listeners.userInfo(5343993); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=5343993&amp;amp;size=small&amp;amp;timestamp=1610251593" alt="caspian2" style="background-image:url(http://www.wikidot.com/userkarma.php?u=5343993)"/></a><a href="http://www.wikidot.com/user:info/caspian2" onclick="WIKIDOT.page.listeners.userInfo(5343993); return false;" >caspian2</a></span> <span class="odate time_1609479483 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">01 Jan 2021 05:38</span>
														</div>
