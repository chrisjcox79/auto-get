<tr>
<th>YEA</th>
<th>NAY</th>
<th>ABSTAIN</th>
</tr>
<tr>
<td>O5-01</td>
<td>O5-02</td>
<td>O5-13</td>
</tr>
<tr>
<td>O5-03</td>
<td>O5-04</td>
<td></td>
</tr>
<tr>
<td>O5-06</td>
