                    <div id="page-content">
                        

<div style="text-align: center;"><img src="http://www.scp-wiki.net/local--files/and-i-m-the-star/Logo" alt="Logo" class="image" /><br />
<br />
<div class="page-rate-widget-box"><span class="rate-points">rating:&nbsp;<span class="number prw54353">+56</span></span><span class="rateup btn btn-default"><a title="I like it" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.rate(event, 1)">+</a></span><span class="ratedown btn btn-default"><a title="I don't like it" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.rate(event, -1)">&#8211;</a></span><span class="cancel btn btn-default"><a title="Cancel my vote" href="javascript:;" onclick="WIKIDOT.modules.PageRateWidgetModule.listeners.cancelVote(event)">x</a></span></div></div>
