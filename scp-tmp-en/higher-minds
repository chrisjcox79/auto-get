}

input.text:hover {
    border: 1px dashed #000;
    color: #fff;
}

div#lock-info {
    background-color: var(--bg-light);
}

/* BLOCKQUOTES */

blockquote,
div.blockquote {
    background:  var(--bg-dark);
    border-width: 2px;
    border-style: solid;
    border-color: var(--bg-light);
}

