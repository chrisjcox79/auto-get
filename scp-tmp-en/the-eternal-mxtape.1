				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/rubyjx" onclick="WIKIDOT.page.listeners.userInfo(4943614); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=4943614&amp;amp;size=small&amp;amp;timestamp=1610203364" alt="RubyJX" style="background-image:url(http://www.wikidot.com/userkarma.php?u=4943614)"/></a><a href="http://www.wikidot.com/user:info/rubyjx" onclick="WIKIDOT.page.listeners.userInfo(4943614); return false;" >RubyJX</a></span> <span class="odate time_1580837701 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">04 Feb 2020 17:35</span>
														</div>
