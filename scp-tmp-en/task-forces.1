				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/wrongjohnsilver" onclick="WIKIDOT.page.listeners.userInfo(2000367); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=2000367&amp;amp;size=small&amp;amp;timestamp=1610249165" alt="WrongJohnSilver" style="background-image:url(http://www.wikidot.com/userkarma.php?u=2000367)"/></a><a href="http://www.wikidot.com/user:info/wrongjohnsilver" onclick="WIKIDOT.page.listeners.userInfo(2000367); return false;" >WrongJohnSilver</a></span> <span class="odate time_1484863253 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">19 Jan 2017 22:00</span>
														</div>
