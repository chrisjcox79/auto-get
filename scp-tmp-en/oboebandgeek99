.container-genius {
    background-color: rgb(var(--swatch-primary), 0.05);
    padding: 0rem 0em 0em 0em;
    margin-top: 0rem;
    border: 0.0625rem #CCCCCC solid;
    border: 0.0625rem rgba(var(--swatch-border-color),0.15) solid;
    position: relative;
}

.genius_block {
    display: inline;
    font-family: var(--body-font);
}

.genius_content,
.genius_content * {
    display: block;
    position: absolute;
    right: -14rem;
    width: 10rem;
    line-height: 1.2;
    font-family: var(--body-font);
    padding: 0.5rem 0.25rem 0.5rem 0.5rem;
    text-shadow: initial;
    filter: initial;
    color: rgb(var(--black-monochrome));
    transition:
     opacity 600ms cubic-bezier(0.4, 0.0, 0.2, 1),
     transform 300ms cubic-bezier(0.4, 0.0, 0.2, 1);
    pointer-events: none;
    font-weight: normal;
    font-size: calc(var(--base-font-size) * 0.9);
    text-indent: 0.75rem;
    letter-spacing: 0.0125rem;
    z-index: 20;
}

.genius_content::before {
    background-color: rgb(var(--swatch-primary));
    bottom: 0;
    content: " ";
    display: block;
    left: 0;
    position: absolute;
    top: 0.5em;
    width: 0.125rem;
 }

.genius_content::after {
    width: 0;
    height: 0;
    border-top: 0.625rem solid transparent;
    border-bottom: 0.625rem solid transparent;
    border-right:0.625rem solid rgb(var(--swatch-primary));
    content: '';
    display: block;
    left: -0.625rem;
    bottom: calc(50% - 1em);
    position: absolute;
 }

.genius_highlight {
    cursor: pointer;
    background-color: rgb(var(--very-light-gray-monochrome));
    box-shadow:
    .01em 0 0 rgb(var(--very-light-gray-monochrome)),
    -.01em 0 0 rgb(var(--very-light-gray-monochrome));
    display: inline;
}

.genius_highlight:hover {
    background-color: rgb(224,191,192);
    box-shadow:
    .01em 0 0 rgb(224,191,192),
    -.01em 0 0 rgb(224,191,192);
}

.genius_highlight + span {
    transform: translateX(-25%) translateY(calc((1% + 1em) * -1));
    opacity: 0;
}

.genius_highlight:hover + span {
    transform: translateX(0) translateY(calc((1% + 1em) * -1));
    opacity: 1;
}

@media (max-width: 1200px) {
    .genius_content {
          position: fixed;
