				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/gopher-chucks" onclick="WIKIDOT.page.listeners.userInfo(7069900); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=7069900&amp;amp;size=small&amp;amp;timestamp=1610226577" alt="Gopher-Chucks" style="background-image:url(http://www.wikidot.com/userkarma.php?u=7069900)"/></a><a href="http://www.wikidot.com/user:info/gopher-chucks" onclick="WIKIDOT.page.listeners.userInfo(7069900); return false;" >Gopher-Chucks</a></span> <span class="odate time_1609890761 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">05 Jan 2021 23:52</span>
