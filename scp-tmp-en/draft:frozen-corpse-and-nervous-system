				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/grigori-karpin" onclick="WIKIDOT.page.listeners.userInfo(4558017); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=4558017&amp;amp;size=small&amp;amp;timestamp=1610226577" alt="Grigori Karpin" style="background-image:url(http://www.wikidot.com/userkarma.php?u=4558017)"/></a><a href="http://www.wikidot.com/user:info/grigori-karpin" onclick="WIKIDOT.page.listeners.userInfo(4558017); return false;" >Grigori Karpin</a></span> <span class="odate time_1609906447 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">06 Jan 2021 04:14</span>
														</div>
