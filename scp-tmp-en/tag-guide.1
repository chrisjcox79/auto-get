							</div>
									
			<div id="post-options-1568700" class="options" style="display: none">
			</div>
		</div>
		<div class="short">
							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,1568700)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,1568700)">Re: Proposed new tag</a> by <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/aelanna" onclick="WIKIDOT.page.listeners.userInfo(334454); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=334454&amp;amp;size=small&amp;amp;timestamp=1610226305" alt="Aelanna" style="background-image:url(http://www.wikidot.com/userkarma.php?u=334454)"/></a><a href="http://www.wikidot.com/user:info/aelanna" onclick="WIKIDOT.page.listeners.userInfo(334454); return false;" >Aelanna</a></span>, <span class="odate time_1348093259 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">19 Sep 2012 22:20</span>
		</div>
