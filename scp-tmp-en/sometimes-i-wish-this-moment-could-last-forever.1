					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/abettik" onclick="WIKIDOT.page.listeners.userInfo(1700758); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1700758&amp;amp;size=small&amp;amp;timestamp=1610227389" alt="Abettik" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1700758)"/></a><a href="http://www.wikidot.com/user:info/abettik" onclick="WIKIDOT.page.listeners.userInfo(1700758); return false;" >Abettik</a></span> <span class="odate time_1508773268 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">23 Oct 2017 15:41</span>
