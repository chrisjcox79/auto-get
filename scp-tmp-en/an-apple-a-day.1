    <div class="post-container" id="fpc-4405932">
                      
		<div class="post" id="post-4405932">
		<div class="long">
			<div class="head">
									<div class="options">
						<a href="javascript:;" onclick="togglePostFold(event,4405932)" class="btn btn-default btn-small btn-sm">Fold</a>
