				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/lurkd" onclick="WIKIDOT.page.listeners.userInfo(1500566); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1500566&amp;amp;size=small&amp;amp;timestamp=1610227302" alt="LurkD" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1500566)"/></a><a href="http://www.wikidot.com/user:info/lurkd" onclick="WIKIDOT.page.listeners.userInfo(1500566); return false;" >LurkD</a></span> <span class="odate time_1556039498 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">23 Apr 2019 17:11</span>
