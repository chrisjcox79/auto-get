		<div class="short">
							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,3718369)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,3718369)"></a> by <span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/shaggydredlocks" onclick="WIKIDOT.page.listeners.userInfo(1722371); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1722371&amp;amp;size=small&amp;amp;timestamp=1610236584" alt="Shaggydredlocks" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1722371)"/></a><a href="http://www.wikidot.com/user:info/shaggydredlocks" onclick="WIKIDOT.page.listeners.userInfo(1722371); return false;" >Shaggydredlocks</a></span>, <span class="odate time_1519279159 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">22 Feb 2018 05:59</span>
