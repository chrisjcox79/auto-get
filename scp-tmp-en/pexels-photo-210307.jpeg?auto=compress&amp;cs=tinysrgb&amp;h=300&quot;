				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/djkaktus" onclick="WIKIDOT.page.listeners.userInfo(1888434); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1888434&amp;amp;size=small&amp;amp;timestamp=1610252564" alt="djkaktus" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1888434)"/></a><a href="http://www.wikidot.com/user:info/djkaktus" onclick="WIKIDOT.page.listeners.userInfo(1888434); return false;" >djkaktus</a></span> <span class="odate time_1528392596 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">07 Jun 2018 17:29</span>
														</div>
