					<item>
				<guid>http://www.scpwiki.com/forum/t-7060165#post-3918274</guid>
				<title>I caught one //this big//</title>
				<link>http://www.scpwiki.com/forum/t-7060165/scp-4222#post-3918274</link>
				<description></description>
				<pubDate>Mon, 20 Aug 2018 05:26:19 +0000</pubDate>
				<wikidot:authorName>fieldstone</wikidot:authorName>				<wikidot:authorUserId>1436137</wikidot:authorUserId>				<content:encoded>
