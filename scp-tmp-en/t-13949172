					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/btracker" onclick="WIKIDOT.page.listeners.userInfo(7184718); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=7184718&amp;amp;size=small&amp;amp;timestamp=1610249262" alt="Btracker" style="background-image:url(http://www.wikidot.com/userkarma.php?u=7184718)"/></a><a href="http://www.wikidot.com/user:info/btracker" onclick="WIKIDOT.page.listeners.userInfo(7184718); return false;" >Btracker</a></span> <span class="odate time_1610232085 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">09 Jan 2021 22:41</span>
