				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/thekillerax" onclick="WIKIDOT.page.listeners.userInfo(1832151); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1832151&amp;amp;size=small&amp;amp;timestamp=1610204958" alt="Thekillerax" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1832151)"/></a><a href="http://www.wikidot.com/user:info/thekillerax" onclick="WIKIDOT.page.listeners.userInfo(1832151); return false;" >Thekillerax</a></span> <span class="odate time_1417158366 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">28 Nov 2014 07:06</span>
														</div>
