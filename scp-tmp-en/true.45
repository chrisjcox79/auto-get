.info-container .collapsible-block-unfolded-link {
    display: block;
    margin: 0 auto;
    height: 1.5em;
    width: 100%;
}

.info-container .collapsible-block-unfolded {
    border: 1px solid #BBB;
    border-top: none;
}

.info-container .collapsible-block-content {
    text-align: left;
    padding-bottom: 30px;
}

.info-container .collapsible-block-content > div:nth-child(1) > p {
    margin: 2em;
}

.u-faq a:link {
    font-size: 80%;
}

#u-author_block > p > a {
    display: inline;
    padding: 0.8em;
    background: var(--barColour);
    color: var(--linkColour);
    border-radius: 0.25vw;
    box-shadow: 0 0px 4px rgba(0, 0, 0, 0);
    transition: -webkit-backdrop-filter .3s, backdrop-filter .3s, box-shadow .3s;
}

#u-author_block > p > a:hover {
    box-shadow: 0px 3px 4px rgba(0, 0, 0, .8);
    text-decoration: none;
}

.translation_block {
    display: block;
    margin: 0 2em;
    width: calc(100% - 4em);
    text-align: center;
}

.translation_block iframe{
    width: 17.2em;
}

.translation_block > p > iframe {
    margin: 0 auto;
    width: 19em;
    display: block;
}

.translation_block > p {
    margin: 0;
}
</style>
<style>
sup { 
vertical-align: top; position: relative; top: -0.5em; 
}
:root{ 
--cutColour: #fafafa;
