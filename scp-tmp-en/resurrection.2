				<div class="info">
					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/thedeadlymoose" onclick="WIKIDOT.page.listeners.userInfo(732274); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=732274&amp;amp;size=small&amp;amp;timestamp=1610161927" alt="thedeadlymoose" style="background-image:url(http://www.wikidot.com/userkarma.php?u=732274)"/></a><a href="http://www.wikidot.com/user:info/thedeadlymoose" onclick="WIKIDOT.page.listeners.userInfo(732274); return false;" >thedeadlymoose</a></span> <span class="odate time_1427703592 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">30 Mar 2015 08:19</span>
														</div>
