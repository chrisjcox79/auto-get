					<span class="printuser avatarhover"><a href="http://www.wikidot.com/user:info/worldisquiet5256" onclick="WIKIDOT.page.listeners.userInfo(1773975); return false;"  ><img class="small" src="http://www.wikidot.com/avatar.php?userid=1773975&amp;amp;size=small&amp;amp;timestamp=1610161927" alt="WorldisQuiet5256" style="background-image:url(http://www.wikidot.com/userkarma.php?u=1773975)"/></a><a href="http://www.wikidot.com/user:info/worldisquiet5256" onclick="WIKIDOT.page.listeners.userInfo(1773975); return false;" >WorldisQuiet5256</a></span> <span class="odate time_1570483054 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">07 Oct 2019 21:17</span>
