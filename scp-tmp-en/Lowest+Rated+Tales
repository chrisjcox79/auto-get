&lt;td style=&quot;text-align: right;&quot;&gt;&lt;span style=&quot;font-size:125%;&quot;&gt;&lt;span style=&quot;color: #990000&quot;&gt;&lt;strong&gt;BURIAL BROKEN&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
&lt;/tr&gt;
