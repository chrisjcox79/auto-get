&lt;div style=&quot;display: none&quot;&gt;&lt;/div&gt;
&lt;p&gt;by &lt;span class=&quot;printuser avatarhover&quot;&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/malvarik1&quot;  &gt;&lt;img class=&quot;small&quot; src=&quot;http://www.wikidot.com/avatar.php?userid=5143999&amp;amp;amp;size=small&amp;amp;amp;timestamp=1610226518&quot; alt=&quot;Malvarik1&quot; style=&quot;background-image:url(http://www.wikidot.com/userkarma.php?u=5143999)&quot; /&gt;&lt;/a&gt;&lt;a href=&quot;http://www.wikidot.com/user:info/malvarik1&quot;  &gt;Malvarik1&lt;/a&gt;&lt;/span&gt;&lt;/p&gt;
</description>
