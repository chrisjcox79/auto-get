&lt;td&gt;&lt;span style=&quot;font-size:125%;&quot;&gt;&lt;strong&gt;Solution Class:&lt;/strong&gt; Buried&lt;/span&gt;&lt;/td&gt;
&lt;td style=&quot;text-align: right;&quot;&gt;&lt;span style=&quot;font-size:125%;&quot;&gt;&lt;span style=&quot;color: #990000&quot;&gt;&lt;strong&gt;UNACCEPTABLE&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
