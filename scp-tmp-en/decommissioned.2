		<div class="short">
							<a class="options btn btn-default btn-mini btn-xs" href="javascript:;" onclick="togglePostFold(event,2168492)" c>Unfold</a>
						<a class="title" href="javascript:;" onclick="togglePostFold(event,2168492)"></a> by <span class="printuser deleted" data-id="1361261"><img class="small" src="http://www.wikidot.com/common--images/avatars/default/a16.png" alt=""/>(account deleted)</span>, <span class="odate time_1417253620 format_%25e%20%25b%20%25Y%2C%20%25H%3A%25M%7Cagohover">29 Nov 2014 09:33</span>
		</div>
